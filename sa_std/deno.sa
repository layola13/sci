[END_MACRO]

[MACRO] DENO_JSON_STRINGIFY %out_status, %out_buffer, %node
    __deno_json_stringify_slot_%out_buffer = stack_alloc 8
    %out_status = call @sa_json_stringify(%node, &__deno_json_stringify_slot_%out_buffer)
    %out_buffer = load __deno_json_stringify_slot_%out_buffer+0 as ptr
[END_MACRO]

[MACRO] DENO_JSON_BUFFER_SLICE %out_ptr, %out_len, %buffer
