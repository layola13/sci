[END_MACRO]

[MACRO] DENO_JSON_BUFFER_FREE %buffer
    EXPAND JSON_BUFFER_FREE %buffer
[END_MACRO]

[MACRO] DENO_JSON_FREE %node
    EXPAND JSON_FREE %node
[END_MACRO]

[MACRO] DENO_FREE_BUFFER %buffer, %out_status
