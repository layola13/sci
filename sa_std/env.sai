// SA-facing contracts for environment variable helpers.
// Env values are copied into owned buffer handles and must be freed explicitly.
@extern sa_env_get(&key: ptr, key_len: u64) -> u64
@extern sa_env_has(&key: ptr, key_len: u64) -> i32

@extern sa_env_buffer_data(buffer: u64) -> &ptr
@extern sa_env_buffer_len(buffer: u64) -> u64
@extern sa_env_buffer_free(^buffer: u64) -> i32
