@import "../sa_std/core/sa_core.sa"

@test "cfg macro selects true and false branches"():
L_ENTRY:
    EXPAND CFG true_flag, true
    EXPAND CFG false_flag, 0
    EXPAND CFG! rust_true_flag, true
    EXPAND CFG! rust_false_flag, 0
    ok1 = eq true_flag, 1
    ok2 = eq false_flag, 0
    ok3 = eq rust_true_flag, 1
    ok4 = eq rust_false_flag, 0
    !true_flag
    !false_flag
    !rust_true_flag
    !rust_false_flag
    !ok1
    !ok2
    !ok3
    !ok4
    return
