@import "../sa_std/io.sa"

@const PRINT_MSG = utf8:"abc"
@const PRINTLN_MSG = utf8:"def"
@const EPRINT_MSG = utf8:"ghi"
@const EPRINTLN_MSG = utf8:"jkl"

@test "io print macros expand and run"():
L_ENTRY:
    EXPAND PRINT PRINT_MSG, 3
    EXPAND PRINTLN PRINTLN_MSG, 3
    writer = call @sa_io_stdout()
    EXPAND WRITE writer, PRINT_MSG, 3
    EXPAND WRITELN writer, PRINTLN_MSG, 3
    EXPAND EPRINT EPRINT_MSG, 3
    EXPAND EPRINTLN EPRINTLN_MSG, 3
    !writer
    return
