@import "../sa_std/core/option.sal"
@import "../sa_std/core/option.sa"
@import "../sa_std/core/result.sal"
@import "../sa_std/core/result.sa"

@test "matches macros dispatch option and result tags"():
L_ENTRY:
    some_opt = alloc Option_SIZE
    store some_opt+Option_tag, Option_SOME as u64
    store some_opt+Option_value, 12 as u64
    none_opt = alloc Option_SIZE
    store none_opt+Option_tag, Option_NONE as u64
    store none_opt+Option_value, 0 as u64

    ok_res = alloc Result_SIZE
    store ok_res+Result_tag, Result_OK as u64
    store ok_res+Result_ok, 34 as u64
    store ok_res+Result_err, 0 as u64
    err_res = alloc Result_SIZE
    store err_res+Result_tag, Result_ERR as u64
    store err_res+Result_ok, 0 as u64
    store err_res+Result_err, 56 as u64

    EXPAND MATCHES_OPTION some_matches, some_opt, Option_SOME
    EXPAND MATCHES_OPTION none_matches, none_opt, Option_SOME
    EXPAND MATCHES_RESULT ok_matches, ok_res, Result_OK
    EXPAND MATCHES_RESULT err_matches, err_res, Result_OK

    ok1 = eq some_matches, 1
    ok2 = eq none_matches, 0
    ok3 = eq ok_matches, 1
    ok4 = eq err_matches, 0

    !some_matches
    !none_matches
    !ok_matches
    !err_matches
    !ok1
    !ok2
    !ok3
    !ok4
    !some_opt
    !none_opt
    !ok_res
    !err_res
    return
