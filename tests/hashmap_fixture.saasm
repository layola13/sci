@import "../sa_std/collections/hashmap.saasm"

@const KEY_A = utf8:"alpha"
@const KEY_B = utf8:"bravo"
@const KEY_C = utf8:"charlie"
@const VALUE_A = utf8:"A\n"
@const VALUE_B = utf8:"B\n"
@const VALUE_C = utf8:"C\n"

@main() -> i32:
L_ENTRY:
    map = 0 as ptr
    key_a = 0 as ptr
    key_b = 0 as ptr
    key_c = 0 as ptr
    value_a = 0 as ptr
    value_b = 0 as ptr
    value_c = 0 as ptr
    got_a = 0 as ptr
    got_b = 0 as ptr
    got_c = 0 as ptr
    removed_b = 0 as ptr
    missing_b = 0 as ptr

    EXPAND MAP_NEW map
    key_a = &KEY_A
    key_b = &KEY_B
    key_c = &KEY_C
    value_a = &VALUE_A
    value_b = &VALUE_B
    value_c = &VALUE_C

    EXPAND MAP_PUT map, key_a, value_a
    EXPAND MAP_PUT map, key_b, value_b
    EXPAND MAP_PUT map, key_c, value_c
    EXPAND MAP_PUT map, key_b, value_c

    EXPAND MAP_GET got_a, map, key_a
    EXPAND MAP_GET got_b, map, key_b
    EXPAND MAP_GET got_c, map, key_c
    EXPAND MAP_DEL removed_b, map, key_b
    EXPAND MAP_GET missing_b, map, key_b

    ok_a = eq got_a, value_a
    ok_b = eq got_b, value_c
    ok_c = eq got_c, value_c
    ok_removed = ne removed_b, 0
    ok_missing = eq missing_b, 0
    ok01 = and ok_a, ok_b
    ok02 = and ok01, ok_c
    ok03 = and ok02, ok_removed
    ok = and ok03, ok_missing

    !missing_b
    !removed_b
    !got_c
    !got_b
    !got_a
    !value_c
    !value_b
    !value_a
    !key_c
    !key_b
    !key_a
    EXPAND MAP_FREE map
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    return 0

L_ERR:
    !ok
    return 1
