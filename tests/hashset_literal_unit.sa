@import "../sa_std/collections/hashset.sa"

@const KEY_A = utf8:"alpha"
@const KEY_B = utf8:"bravo"

@test "set literal macro inserts two entries"():
L_ENTRY:
    key_a = &KEY_A
    key_b = &KEY_B
    EXPAND SET_LIT2 set, key_a, key_b
    EXPAND SET_LEN len0, set
    EXPAND SET_CONTAINS has_a, set, key_a
    EXPAND SET_CONTAINS has_b, set, key_b
    EXPAND SET_CONTAINS has_missing, set, key_a
    ok_len = eq len0, 2
    ok_has_a = eq has_a, 1
    ok_has_b = eq has_b, 1
    ok = and ok_len, ok_has_a
    ok = and ok, ok_has_b
    !has_missing
    !has_b
    !has_a
    !len0
    !key_b
    !key_a
    EXPAND SET_FREE set
    return
