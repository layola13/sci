@test "35_iterator_fold slice fold"():
L_ENTRY:
    values = stack_alloc 24
    store values+0, 2 as u64
    store values+8, 3 as u64
    store values+16, 2 as u64
    slice = alloc Slice_SIZE
    EXPAND SLICE_NEW slice, values, 3
    EXPAND ITER_FROM_SLICE iter, slice
    EXPAND ITER_LEN iter_len, iter
    EXPAND ITER_PEEK_U64 item0, iter
    acc1 = add 0, item0
    EXPAND ITER_NEXT_U64 has_next1, item1, iter
    acc2 = add acc1, item1
    EXPAND ITER_NEXT_U64 has_next2, item2, iter
    acc3 = add acc2, item2
    ok = eq acc3, 7
    !iter_len
    !item0
    !item1
    !item2
    !has_next1
    !has_next2
    !acc1
    !acc2
    !acc3
    !iter
    !slice
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    return

L_ERR:
    !ok
    panic(210)

