// This suite condenses representative behaviors from the completed rosetta
// demos into one native-unit-test corpus.

@test "03_if_else branch path"():
L_ENTRY:
    value = call @support_pick_max(10, 20)
    ok = eq value, 20
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    return

L_ERR:
    !ok
    panic(201)

@test "04_loop zero fill"():
L_ENTRY:
    buffer = alloc 4
    store buffer+0, 1 as u8
    store buffer+1, 2 as u8
    store buffer+2, 3 as u8
    store buffer+3, 4 as u8
    call @support_fill_zero(&buffer)
    b0 = load buffer+0 as u8
    b1 = load buffer+1 as u8
    b2 = load buffer+2 as u8
    b3 = load buffer+3 as u8
    ok0 = eq b0, 0
    ok1 = eq b1, 0
    ok2 = eq b2, 0
    ok3 = eq b3, 0
    pair0 = and ok0, ok1
    pair1 = and ok2, ok3
    ok = and pair0, pair1
    !b0
    !b1
    !b2
    !b3
    !ok0
    !ok1
    !ok2
    !ok3
    !pair0
    !pair1
    !buffer
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    return

L_ERR:
    !ok
    panic(206)

