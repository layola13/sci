@test "177_result unwrap and unwrap_err"():
L_ENTRY:
    ok_res = alloc Result_SIZE
    err_res = alloc Result_SIZE
    EXPAND RESULT_SET_OK ok_res, 5
    EXPAND RESULT_SET_ERR err_res, 13
    EXPAND RESULT_UNWRAP value, ok_res
    EXPAND RESULT_UNWRAP_ERR err_value, err_res
    ok_value = eq value, 5
    ok_err = eq err_value, 13
    ok = and ok_value, ok_err
    !value
    !err_value
    !ok_value
    !ok_err
    !ok_res
    !err_res
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    return

L_ERR:
    !ok
