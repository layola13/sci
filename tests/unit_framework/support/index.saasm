@import "json_regex.saasm"
@import "stdlib_surface.saasm"

// Helpers distilled from the rosetta demos that the native unit-test suite
// already covered in separate batches.

@support_pick_max(a: i32, b: i32) -> i32:
L_ENTRY:
    choose_a = sgt a, b
    br choose_a -> L_A, L_B

L_A:
    !choose_a
    !b
    return a

L_B:
    !choose_a
    !a
    return b

@support_make_point(x: i32, y: i32) -> ptr:
L_ENTRY:
    point = alloc 8
    store point+0, x as i32
    store point+4, y as i32
    !x
    !y
    return point

@support_sum_point(^point: ptr) -> i32:
L_ENTRY:
    px = load point+0 as i32
    py = load point+4 as i32
    sum = add px, py
    !px
    !py
    !point
    return sum

@support_dispatch_msg(tag: u32, x: i32, y: i32) -> i32:
L_ENTRY:
    is_move = eq tag, 1
    br is_move -> L_MOVE, L_OTHER

L_MOVE:
    !is_move
    sum = add x, y
    !x
    !y
    return sum

L_OTHER:
    !is_move
    panic(106)

@support_read_twice(&value: ptr) -> i32:
L_ENTRY:
    a = load value+0 as i32
    b = load value+0 as i32
    sum = add a, b
    !a
    !b
    !value
    return sum

@support_identity(value: i32) -> i32:
L_ENTRY:
    return value
