@import "sa_std/encoding/json.sa"
@import "sa_std/text/regex.sa"

@const JSON_DOM = utf8:"{\"name\":\"sci\",\"count\":7,\"ok\":true}"
@const JSON_NAME_KEY = utf8:"name"
@const JSON_COUNT_KEY = utf8:"count"
@const JSON_OK_KEY = utf8:"ok"
@const JSON_SCI_VALUE = utf8:"sci"
@const JSON_DOM_EXPECTED = utf8:"{\"name\":\"sci\",\"count\":7,\"ok\":true}"
@const JSON_STREAM_DOC = utf8:"{\"name\":\"sci\",\"count\":7}"
@const JSON_REGEX_PATTERN = utf8:"h([a-z]+)o ([a-z]+)"
@const JSON_REGEX_TEXT = utf8:"hello world"
@const JSON_REGEX_GROUP0 = utf8:"hello world"
@const JSON_REGEX_GROUP1 = utf8:"ell"
@const JSON_REGEX_GROUP2 = utf8:"world"

#def JSON_DOM_LEN = 34
#def JSON_NAME_KEY_LEN = 4
#def JSON_COUNT_KEY_LEN = 5
#def JSON_OK_KEY_LEN = 2
#def JSON_SCI_VALUE_LEN = 3
#def JSON_STREAM_DOC_LEN = 24
#def JSON_REGEX_PATTERN_LEN = 19
#def JSON_REGEX_TEXT_LEN = 11
#def JSON_REGEX_GROUP0_LEN = 11
#def JSON_REGEX_GROUP1_LEN = 3
#def JSON_REGEX_GROUP2_LEN = 5

@support_bytes_eq(&lhs: ptr, lhs_len: u64, *rhs: ptr, rhs_len: u64) -> i32:
L_ENTRY:
    same_len = eq lhs_len, rhs_len
    br same_len -> L_EQ_LOOP, L_EQ_FALSE

L_EQ_LOOP:
    idx_slot = stack_alloc 8
    store idx_slot+0, 0 as u64
    jmp L_EQ_HEAD

L_EQ_HEAD:
    idx = load idx_slot+0 as u64
    done = eq idx, lhs_len
    br done -> L_EQ_TRUE, L_EQ_BODY

L_EQ_BODY:
    lhs_ip = ptr_add lhs, idx
    rhs_ip = ptr_add rhs, idx
    lhs_byte = load lhs_ip+0 as u8
    rhs_byte = load rhs_ip+0 as u8
    bytes_eq = eq lhs_byte, rhs_byte
    !lhs_ip
    !rhs_ip
    br bytes_eq -> L_EQ_NEXT, L_EQ_FALSE_CLEAN

L_EQ_NEXT:
    next_idx = add idx, 1
    store idx_slot+0, next_idx as u64
    !idx
    !done
    !lhs_byte
    !rhs_byte
    !bytes_eq
    !next_idx
    jmp L_EQ_HEAD

L_EQ_TRUE:
    result = add 0, 1
    !lhs
    !rhs
    !lhs_len
    !rhs_len
    !same_len
    return result

L_EQ_FALSE_CLEAN:
    result = add 0, 0
    !idx
    !done
    !lhs_byte
    !rhs_byte
    !bytes_eq
    !lhs
    !rhs
    !lhs_len
    !rhs_len
    !same_len
    return result

L_EQ_FALSE:
    result = add 0, 0
    !lhs
    !rhs
    !lhs_len
    !rhs_len
    !same_len
    return result

@support_json_dom_roundtrip() -> void:
L_ENTRY:
    root = call @sa_json_parse(&JSON_DOM, JSON_DOM_LEN)
    parse_ok = ne root, 0
    br parse_ok -> L_KIND, L_FAIL_PARSE

L_FAIL_PARSE:
    panic(401)

L_KIND:
    kind = call @sa_json_kind(root)
    kind_ok = eq kind, SA_JSON_KIND_OBJECT
    !kind
    br kind_ok -> L_COUNT, L_FAIL_KIND

L_FAIL_KIND:
    root_free_res = call @sa_json_free(^root)
    !root_free_res
    panic(402)

L_COUNT:
    !kind_ok
    count_slot = stack_alloc 8
    count_res = call @sa_json_value_count(root, &count_slot)
    count_status = add count_res, 0
    !count_res
    count_value = load count_slot+0 as u64
    count_status_ok = eq count_status, 0
    count_value_ok = eq count_value, 3
    count_ok = and count_status_ok, count_value_ok
    !count_value
    !count_status_ok
    !count_value_ok
    br count_ok -> L_NAME_GET, L_FAIL_COUNT_ROOT

L_FAIL_COUNT_ROOT:
    root_free_res = call @sa_json_free(^root)
    !root_free_res
    panic(403)

L_NAME_GET:
    !count_ok
    name_slot = stack_alloc 8
    name_res = call @sa_json_object_get(root, &JSON_NAME_KEY, JSON_NAME_KEY_LEN, &name_slot)
    name_status = add name_res, 0
    !name_res
    name_status_ok = eq name_status, 0
    br name_status_ok -> L_NAME_HANDLE, L_FAIL_NAME_GET

L_FAIL_NAME_GET:
    !name_status_ok
    root_free_res = call @sa_json_free(^root)
    !root_free_res
    panic(404)

L_NAME_HANDLE:
    name_handle = load name_slot+0 as ptr
    name_kind = call @sa_json_kind(name_handle)
    name_kind_ok = eq name_kind, SA_JSON_KIND_STRING
    name_ptr = call @sa_json_string_ptr(name_handle)
    name_len = call @sa_json_string_len(name_handle)
    name_len_ok = eq name_len, JSON_SCI_VALUE_LEN
    name_text_match = call @support_bytes_eq(&name_ptr, name_len, *JSON_SCI_VALUE, JSON_SCI_VALUE_LEN)
    name_text_ok = eq name_text_match, 1
    name_ok_0 = and name_kind_ok, name_len_ok
    name_ok = and name_ok_0, name_text_ok
    !name_kind
    !name_ptr
    !name_len
    !name_text_match
    !name_kind_ok
    !name_len_ok
    !name_text_ok
    !name_ok_0
    br name_ok -> L_NAME_FREE, L_FAIL_NAME

L_NAME_FREE:
    !name_ok
    !name_status_ok
    name_free_res = call @sa_json_free(^name_handle)
    !name_free_res
    jmp L_COUNT_GET

L_FAIL_NAME:
    !name_ok
    root_free_res = call @sa_json_free(^root)
    !root_free_res
    panic(406)

L_COUNT_GET:
    count2_slot = stack_alloc 8
    count_res = call @sa_json_object_get(root, &JSON_COUNT_KEY, JSON_COUNT_KEY_LEN, &count2_slot)
    count_status = add count_res, 0
    !count_res
    count_status_ok = eq count_status, 0
    br count_status_ok -> L_COUNT_HANDLE, L_FAIL_COUNT_GET

L_FAIL_COUNT_GET:
    !count_status_ok
    root_free_res = call @sa_json_free(^root)
    !root_free_res
    panic(407)

L_COUNT_HANDLE:
    !count_status_ok
    count_handle = load count2_slot+0 as ptr
    count_value_slot = stack_alloc 8
    count_value_res = call @sa_json_as_i64(count_handle, &count_value_slot)
    count_value_status = add count_value_res, 0
    !count_value_res
    count_value = load count_value_slot+0 as i64
    count_value_status_ok = eq count_value_status, 0
    count_value_ok = eq count_value, 7
    count_ok = and count_value_status_ok, count_value_ok
    !count_value_status
    !count_value
    !count_value_status_ok
    !count_value_ok
    br count_ok -> L_OK_GET, L_FAIL_COUNT_HANDLE

L_FAIL_COUNT_HANDLE:
    count_free_res = call @sa_json_free(^count_handle)
    !count_free_res
    root_free_res = call @sa_json_free(^root)
    !root_free_res
    panic(405)

L_OK_GET:
    !count_ok
    ok_slot = stack_alloc 8
    ok_res = call @sa_json_object_get(root, &JSON_OK_KEY, JSON_OK_KEY_LEN, &ok_slot)
    ok_status = add ok_res, 0
    !ok_res
    ok_status_ok = eq ok_status, 0
    br ok_status_ok -> L_OK_HANDLE, L_FAIL_OK_GET

L_FAIL_OK_GET:
    !ok_status_ok
    count_free_res = call @sa_json_free(^count_handle)
    !count_free_res
    root_free_res = call @sa_json_free(^root)
    !root_free_res
    panic(408)

L_OK_HANDLE:
    !ok_status_ok
    ok_handle = load ok_slot+0 as ptr
    ok_value_slot = stack_alloc 8
    ok_value_res = call @sa_json_as_bool(ok_handle, &ok_value_slot)
    ok_value_status = add ok_value_res, 0
    !ok_value_res
    ok_value = load ok_value_slot+0 as u8
    ok_value_status_ok = eq ok_value_status, 0
    ok_value_ok = eq ok_value, 1
    ok_ok = and ok_value_status_ok, ok_value_ok
    !ok_value_status
    !ok_value
    !ok_value_status_ok
    !ok_value_ok
    br ok_ok -> L_STRINGIFY, L_FAIL_OK

L_FAIL_OK:
    !ok_ok
    ok_free_res = call @sa_json_free(^ok_handle)
    !ok_free_res
    count_free_res = call @sa_json_free(^count_handle)
    !count_free_res
    root_free_res = call @sa_json_free(^root)
    !root_free_res
    panic(409)

L_STRINGIFY:
    !ok_ok
    count_free_res = call @sa_json_free(^count_handle)
    !count_free_res
    ok_free_res = call @sa_json_free(^ok_handle)
    !ok_free_res
    stringify_slot = stack_alloc 8
    stringify_res = call @sa_json_stringify(root, &stringify_slot)
    stringify_status = add stringify_res, 0
    !stringify_res
    stringify_buffer = load stringify_slot+0 as ptr
    stringify_status_ok = eq stringify_status, 0
    br stringify_status_ok -> L_STRINGIFY_BUFFER, L_FAIL_STRINGIFY

L_FAIL_STRINGIFY:
    root_free_res = call @sa_json_free(^root)
    !root_free_res
    panic(410)

L_STRINGIFY_BUFFER:
    stringify_buffer_ptr = call @sa_json_buffer_data(&stringify_buffer)
    stringify_buffer_len = call @sa_json_buffer_len(&stringify_buffer)
    stringify_buffer_len_ok = eq stringify_buffer_len, JSON_DOM_LEN
    stringify_buffer_match = call @support_bytes_eq(&stringify_buffer_ptr, stringify_buffer_len, *JSON_DOM_EXPECTED, JSON_DOM_LEN)
    stringify_buffer_ok = eq stringify_buffer_match, 1
    stringify_all_ok = and stringify_status_ok, stringify_buffer_len_ok
    stringify_all_ok = and stringify_all_ok, stringify_buffer_ok
    !stringify_buffer_ptr
    !stringify_buffer_len
    !stringify_buffer_match
    !stringify_buffer_len_ok
    !stringify_buffer_ok
    br stringify_all_ok -> L_DONE, L_FAIL_STRINGIFY_COMPARE

L_FAIL_STRINGIFY_COMPARE:
    stringify_buffer_free_res = call @sa_json_buffer_free(^stringify_buffer)
    !stringify_buffer_free_res
    root_free_res = call @sa_json_free(^root)
    !root_free_res
    panic(411)

L_DONE:
    stringify_buffer_free_res = call @sa_json_buffer_free(^stringify_buffer)
    !stringify_buffer_free_res
    root_free_res = call @sa_json_free(^root)
    !root_free_res
    return

@support_json_stream_tokens() -> void:
L_ENTRY:
    stream = call @sa_json_stream_new(&JSON_STREAM_DOC, JSON_STREAM_DOC_LEN)
    has_stream = ne stream, 0
    br has_stream -> L_TOK0, L_FAIL_STREAM_NEW

L_FAIL_STREAM_NEW:
    panic(501)

L_TOK0:
    token0 = call @sa_json_stream_next(stream)
    token0_ok = eq token0, SA_JSON_TOKEN_OBJECT_BEGIN
    !token0
    br token0_ok -> L_TOK1, L_FAIL_TOK0

L_FAIL_TOK0:
    !token0_ok
    stream_free_res = call @sa_json_stream_free(^stream)
    stream_free_status = load stream_free_res+0 as i32
    !stream_free_res
    !stream_free_status
    panic(502)

L_TOK1:
    token1 = call @sa_json_stream_next(stream)
    token1_ok = eq token1, SA_JSON_TOKEN_STRING
    !token1
    br token1_ok -> L_TOK1_TEXT, L_FAIL_TOK1

L_FAIL_TOK1:
    !token1_ok
    stream_free_res = call @sa_json_stream_free(^stream)
    stream_free_status = load stream_free_res+0 as i32
    !stream_free_res
    !stream_free_status
    panic(503)

L_TOK1_TEXT:
    token1_ptr = call @sa_json_stream_get_slice_ptr(stream)
    token1_len = call @sa_json_stream_get_slice_len(stream)
    token1_len_ok = eq token1_len, JSON_NAME_KEY_LEN
    token1_match = call @support_bytes_eq(&token1_ptr, token1_len, *JSON_NAME_KEY, JSON_NAME_KEY_LEN)
    token1_text_ok = eq token1_match, 1
    token1_all_ok = and token1_len_ok, token1_text_ok
    !token1_ptr
    !token1_len
    !token1_match
    !token1_len_ok
    !token1_text_ok
    br token1_all_ok -> L_TOK2, L_FAIL_TOK1_TEXT

L_FAIL_TOK1_TEXT:
    !token1_all_ok
    stream_free_res = call @sa_json_stream_free(^stream)
    stream_free_status = load stream_free_res+0 as i32
    !stream_free_res
    !stream_free_status
    panic(504)

L_TOK2:
    token2 = call @sa_json_stream_next(stream)
    token2_ok = eq token2, SA_JSON_TOKEN_STRING
    !token2
    br token2_ok -> L_TOK2_TEXT, L_FAIL_TOK2

L_FAIL_TOK2:
    !token2_ok
    stream_free_res = call @sa_json_stream_free(^stream)
    stream_free_status = load stream_free_res+0 as i32
    !stream_free_res
    !stream_free_status
    panic(505)

L_TOK2_TEXT:
    token2_ptr = call @sa_json_stream_get_slice_ptr(stream)
    token2_len = call @sa_json_stream_get_slice_len(stream)
    token2_len_ok = eq token2_len, JSON_SCI_VALUE_LEN
    token2_match = call @support_bytes_eq(&token2_ptr, token2_len, *JSON_SCI_VALUE, JSON_SCI_VALUE_LEN)
    token2_text_ok = eq token2_match, 1
    token2_all_ok = and token2_len_ok, token2_text_ok
    !token2_ptr
    !token2_len
    !token2_match
    !token2_len_ok
    !token2_text_ok
    br token2_all_ok -> L_TOK3, L_FAIL_TOK2_TEXT

L_FAIL_TOK2_TEXT:
    !token2_all_ok
    stream_free_res = call @sa_json_stream_free(^stream)
    stream_free_status = load stream_free_res+0 as i32
    !stream_free_res
    !stream_free_status
    panic(506)

L_TOK3:
    token3 = call @sa_json_stream_next(stream)
    token3_ok = eq token3, SA_JSON_TOKEN_STRING
    !token3
    br token3_ok -> L_TOK3_TEXT, L_FAIL_TOK3

L_FAIL_TOK3:
    !token3_ok
    stream_free_res = call @sa_json_stream_free(^stream)
    stream_free_status = load stream_free_res+0 as i32
    !stream_free_res
    !stream_free_status
    panic(507)

L_TOK3_TEXT:
    token3_ptr = call @sa_json_stream_get_slice_ptr(stream)
    token3_len = call @sa_json_stream_get_slice_len(stream)
    token3_len_ok = eq token3_len, JSON_COUNT_KEY_LEN
    token3_match = call @support_bytes_eq(&token3_ptr, token3_len, *JSON_COUNT_KEY, JSON_COUNT_KEY_LEN)
    token3_text_ok = eq token3_match, 1
    token3_all_ok = and token3_len_ok, token3_text_ok
    !token3_ptr
    !token3_len
    !token3_match
    !token3_len_ok
    !token3_text_ok
    br token3_all_ok -> L_TOK4, L_FAIL_TOK3_TEXT

L_FAIL_TOK3_TEXT:
    !token3_all_ok
    stream_free_res = call @sa_json_stream_free(^stream)
    stream_free_status = load stream_free_res+0 as i32
    !stream_free_res
    !stream_free_status
    panic(508)

L_TOK4:
    token4 = call @sa_json_stream_next(stream)
    token4_ok = eq token4, SA_JSON_TOKEN_NUMBER
    !token4
    br token4_ok -> L_TOK4_TEXT, L_FAIL_TOK4

L_FAIL_TOK4:
    !token4_ok
    stream_free_res = call @sa_json_stream_free(^stream)
    stream_free_status = load stream_free_res+0 as i32
    !stream_free_res
    !stream_free_status
    panic(509)

L_TOK4_TEXT:
    token4_ptr = call @sa_json_stream_get_slice_ptr(stream)
    token4_len = call @sa_json_stream_get_slice_len(stream)
    token4_len_ok = eq token4_len, 1
    token4_match = call @support_bytes_eq(&token4_ptr, token4_len, *"7", 1)
    token4_text_ok = eq token4_match, 1
    token4_all_ok = and token4_len_ok, token4_text_ok
    !token4_ptr
    !token4_len
    !token4_match
    !token4_len_ok
    !token4_text_ok
    br token4_all_ok -> L_TOK5, L_FAIL_TOK4_TEXT

L_FAIL_TOK4_TEXT:
    !token4_all_ok
    stream_free_res = call @sa_json_stream_free(^stream)
    stream_free_status = load stream_free_res+0 as i32
    !stream_free_res
    !stream_free_status
    panic(510)

L_TOK5:
    token5 = call @sa_json_stream_next(stream)
    token5_ok = eq token5, SA_JSON_TOKEN_OBJECT_END
    !token5
    br token5_ok -> L_TOK6, L_FAIL_TOK5

L_FAIL_TOK5:
    !token5_ok
    stream_free_res = call @sa_json_stream_free(^stream)
    stream_free_status = load stream_free_res+0 as i32
    !stream_free_res
    !stream_free_status
    panic(511)

L_TOK6:
    token6 = call @sa_json_stream_next(stream)
    token6_ok = eq token6, SA_JSON_TOKEN_END_OF_DOCUMENT
    !token6
    br token6_ok -> L_STREAM_DONE, L_FAIL_TOK6

L_FAIL_TOK6:
    !token6_ok
    stream_free_res = call @sa_json_stream_free(^stream)
    stream_free_status = load stream_free_res+0 as i32
    !stream_free_res
    !stream_free_status
    panic(512)

L_STREAM_DONE:
    stream_free_res = call @sa_json_stream_free(^stream)
    stream_free_status = load stream_free_res+0 as i32
    !stream_free_res
    !stream_free_status
    !token0_ok
    !token1_ok
    !token2_ok
    !token3_ok
    !token4_ok
    !token5_ok
    !token6_ok
    !token1_all_ok
    !token2_all_ok
    !token3_all_ok
    !token4_all_ok
    return

@support_regex_groups() -> void:
L_ENTRY:
    regex = call @sa_regex_compile(&JSON_REGEX_PATTERN, JSON_REGEX_PATTERN_LEN, SA_REGEX_EXTENDED)
    has_regex = ne regex, 0
    br has_regex -> L_GROUP_COUNT, L_FAIL_COMPILE

L_FAIL_COMPILE:
    panic(601)

L_GROUP_COUNT:
    group_count = call @sa_regex_group_count(regex)
    group_count_ok = eq group_count, 3
    !group_count
    br group_count_ok -> L_MATCH, L_FAIL_GROUP_COUNT

L_FAIL_GROUP_COUNT:
    regex_free_res = call @sa_regex_free(^regex)
    regex_free_status = load regex_free_res+0 as i32
    !regex_free_res
    !regex_free_status
    panic(602)

L_MATCH:
    match = call @sa_regex_match(regex, &JSON_REGEX_TEXT, JSON_REGEX_TEXT_LEN)
    has_match = ne match, 0
    br has_match -> L_GROUP0, L_FAIL_MATCH

L_FAIL_MATCH:
    !has_match
    regex_free_res = call @sa_regex_free(^regex)
    regex_free_status = load regex_free_res+0 as i32
    !regex_free_res
    !regex_free_status
    panic(603)

L_GROUP0:
    group0_ptr = call @sa_regex_group_ptr(match, 0)
    group0_len = call @sa_regex_group_len(match, 0)
    group0_ptr_ok = ne group0_ptr, 0
    group0_len_ok = eq group0_len, JSON_REGEX_GROUP0_LEN
    group0_match = call @support_bytes_eq(&group0_ptr, group0_len, *JSON_REGEX_GROUP0, JSON_REGEX_GROUP0_LEN)
    group0_text_ok = eq group0_match, 1
    group0_ok_0 = and group0_ptr_ok, group0_len_ok
    group0_ok = and group0_ok_0, group0_text_ok
    !group0_ptr
    !group0_len
    !group0_match
    !group0_ptr_ok
    !group0_len_ok
    !group0_text_ok
    !group0_ok_0
    br group0_ok -> L_GROUP1, L_FAIL_GROUP0

L_FAIL_GROUP0:
    !group0_ok
    match_free_res = call @sa_regex_match_free(^match)
    match_free_status = load match_free_res+0 as i32
    !match_free_res
    !match_free_status
    regex_free_res = call @sa_regex_free(^regex)
    regex_free_status = load regex_free_res+0 as i32
    !regex_free_res
    !regex_free_status
    panic(604)

L_GROUP1:
    group1_ptr = call @sa_regex_group_ptr(match, 1)
    group1_len = call @sa_regex_group_len(match, 1)
    group1_ptr_ok = ne group1_ptr, 0
    group1_len_ok = eq group1_len, JSON_REGEX_GROUP1_LEN
    group1_match = call @support_bytes_eq(&group1_ptr, group1_len, *JSON_REGEX_GROUP1, JSON_REGEX_GROUP1_LEN)
    group1_text_ok = eq group1_match, 1
    group1_ok_0 = and group1_ptr_ok, group1_len_ok
    group1_ok = and group1_ok_0, group1_text_ok
    !group1_ptr
    !group1_len
    !group1_match
    !group1_ptr_ok
    !group1_len_ok
    !group1_text_ok
    !group1_ok_0
    br group1_ok -> L_GROUP2, L_FAIL_GROUP1

L_FAIL_GROUP1:
    !group1_ok
    match_free_res = call @sa_regex_match_free(^match)
    match_free_status = load match_free_res+0 as i32
    !match_free_res
    !match_free_status
    regex_free_res = call @sa_regex_free(^regex)
    regex_free_status = load regex_free_res+0 as i32
    !regex_free_res
    !regex_free_status
    panic(605)

L_GROUP2:
    group2_ptr = call @sa_regex_group_ptr(match, 2)
    group2_len = call @sa_regex_group_len(match, 2)
    group2_ptr_ok = ne group2_ptr, 0
    group2_len_ok = eq group2_len, JSON_REGEX_GROUP2_LEN
    group2_match = call @support_bytes_eq(&group2_ptr, group2_len, *JSON_REGEX_GROUP2, JSON_REGEX_GROUP2_LEN)
    group2_text_ok = eq group2_match, 1
    group2_ok_0 = and group2_ptr_ok, group2_len_ok
    group2_ok = and group2_ok_0, group2_text_ok
    !group2_ptr
    !group2_len
    !group2_match
    !group2_ptr_ok
    !group2_len_ok
    !group2_text_ok
    !group2_ok_0
    br group2_ok -> L_REGEX_DONE, L_FAIL_GROUP2

L_FAIL_GROUP2:
    !group2_ok
    match_free_res = call @sa_regex_match_free(^match)
    match_free_status = load match_free_res+0 as i32
    !match_free_res
    !match_free_status
    regex_free_res = call @sa_regex_free(^regex)
    regex_free_status = load regex_free_res+0 as i32
    !regex_free_res
    !regex_free_status
    panic(606)

L_REGEX_DONE:
    match_free_res = call @sa_regex_match_free(^match)
    match_free_status = load match_free_res+0 as i32
    !match_free_res
    !match_free_status
    regex_free_res = call @sa_regex_free(^regex)
    regex_free_status = load regex_free_res+0 as i32
    !regex_free_res
    !regex_free_status
    !has_regex
    !has_match
    !group_count_ok
    !group0_ok
    !group1_ok
    !group2_ok
    return
