@import "../../../sa_std/core/mem.saasm"
@import "../../../sa_std/string.saasm"
@import "../../../sa_std/vec.saasm"
@import "../../../sa_std/collections/hashmap.saasm"
@import "../../../sa_std/collections/btree_map.saasm"
@import "../../../sa_std/net.saasm"
@import "../../../sa_std/fmt.saasm-iface"

@extern sa_string_concat(left: ptr, left_len: u64, right: ptr, right_len: u64) -> ^ptr

@const MEM_SRC = utf8:"ABCDEFGH"
@const MEM_FILL = utf8:"ZZZZZZZZ"
@const STR_EQ_LEFT = utf8:"hello "
@const STR_EQ_RIGHT = utf8:"hello "
@const STR_NE = utf8:"hello?"
@const STR_SUB = utf8:"ell"
@const STR_JOIN_LEFT = utf8:"hello "
@const STR_JOIN_RIGHT = utf8:"world"
@const STR_JOINED = utf8:"hello world"
@const HASHMAP_KEY = utf8:"alpha"
@const HASHMAP_VALUE = utf8:"A\n"
@const BTREE_ALPHA = utf8:"alpha"
@const BTREE_BRAVO = utf8:"bravo"
@const NET_LOOPBACK = utf8:"127.0.0.1"
@const NET_MESSAGE = utf8:"ping"

#def MEM_LEN = 8
#def STR_EQ_LEFT_LEN = 6
#def STR_EQ_RIGHT_LEN = 6
#def STR_NE_LEN = 6
#def STR_SUB_LEN = 3
#def STR_JOIN_LEFT_LEN = 6
#def STR_JOIN_RIGHT_LEN = 5
#def STR_JOINED_LEN = 11
#def HASHMAP_KEY_LEN = 5
#def HASHMAP_VALUE_LEN = 2
#def BTREE_ALPHA_LEN = 5
#def BTREE_BRAVO_LEN = 5
#def NET_LOOPBACK_LEN = 9
#def NET_MESSAGE_LEN = 4

@support_vec_surface() -> void:
L_ENTRY:
    vec0 = 0 as ptr
    EXPAND VEC_NEW vec0
    EXPAND VEC_CAPACITY cap0, vec0
    EXPAND VEC_IS_EMPTY empty0, vec0
    EXPAND VEC_PUSH vec0, 11, 8
    EXPAND VEC_PUSH vec0, 22, 8
    EXPAND VEC_PUSH vec0, 33, 8
    EXPAND VEC_LEN len0, vec0
    EXPAND VEC_CAPACITY cap1, vec0
    EXPAND VEC_GET mid0, vec0, 1
    EXPAND VEC_TRY_POP ok0, pop0, vec0
    EXPAND VEC_LEN len1, vec0
    EXPAND VEC_TRUNCATE vec0, 1
    EXPAND VEC_LEN len2, vec0
    EXPAND VEC_CLEAR vec0
    EXPAND VEC_LEN len3, vec0
    EXPAND VEC_IS_EMPTY empty1, vec0
    EXPAND VEC_WITH_CAPACITY vec1, 4, 8
    EXPAND VEC_CAPACITY cap2, vec1
    EXPAND VEC_LEN len4, vec1
    EXPAND VEC_IS_EMPTY empty2, vec1

    ok_cap0 = eq cap0, 0
    ok_empty0 = eq empty0, 1
    ok_len0 = eq len0, 3
    ok_cap1 = eq cap1, 3
    ok_mid0 = eq mid0, 22
    ok_pop_ok = eq ok0, 1
    ok_pop0 = eq pop0, 33
    ok_len1 = eq len1, 2
    ok_len2 = eq len2, 1
    ok_len3 = eq len3, 0
    ok_empty1 = eq empty1, 1
    ok_cap2 = eq cap2, 4
    ok_len4 = eq len4, 0
    ok_empty2 = eq empty2, 1
    ok01 = and ok_cap0, ok_empty0
    ok02 = and ok01, ok_len0
    ok03 = and ok02, ok_cap1
    ok04 = and ok03, ok_mid0
    ok05 = and ok04, ok_pop_ok
    ok06 = and ok05, ok_pop0
    ok07 = and ok06, ok_len1
    ok08 = and ok07, ok_len2
    ok09 = and ok08, ok_len3
    ok10 = and ok09, ok_empty1
    ok11 = and ok10, ok_cap2
    ok12 = and ok11, ok_len4
    ok = and ok12, ok_empty2
    !cap0
    !empty0
    !len0
    !cap1
    !mid0
    !ok0
    !pop0
    !len1
    !len2
    !len3
    !empty1
    !cap2
    !len4
    !empty2
    !ok_cap0
    !ok_empty0
    !ok_len0
    !ok_cap1
    !ok_mid0
    !ok_pop_ok
    !ok_pop0
    !ok_len1
    !ok_len2
    !ok_len3
    !ok_empty1
    !ok_cap2
    !ok_len4
    !ok_empty2
    !ok01
    !ok02
    !ok03
    !ok04
    !ok05
    !ok06
    !ok07
    !ok08
    !ok09
    !ok10
    !ok11
    !ok12
    EXPAND VEC_FREE vec0
    EXPAND VEC_FREE vec1
    br ok -> L_OK, L_FAIL

L_FAIL:
    !ok
    panic(701)

L_OK:
    !ok
    return

@support_mem_surface() -> void:
L_ENTRY:
    src = alloc MEM_LEN
    store src+0, 65 as u8
    store src+1, 66 as u8
    store src+2, 67 as u8
    store src+3, 68 as u8
    store src+4, 69 as u8
    store src+5, 70 as u8
    store src+6, 71 as u8
    store src+7, 72 as u8
    dst = alloc MEM_LEN
    call @sa_mem_set(&dst, 90, MEM_LEN)
    src_view = alloc Slice_SIZE
    dst_view = alloc Slice_SIZE
    expected_src = alloc Slice_SIZE
    expected_fill = alloc Slice_SIZE
    EXPAND SLICE_NEW src_view, src, MEM_LEN
    EXPAND SLICE_NEW dst_view, dst, MEM_LEN
    EXPAND SLICE_NEW expected_src, &MEM_SRC, MEM_LEN
    EXPAND SLICE_NEW expected_fill, &MEM_FILL, MEM_LEN
    EXPAND STR_EQ src_match, src_view, expected_src
    EXPAND STR_EQ fill_match, dst_view, expected_fill
    call @sa_mem_copy(&dst, &src, MEM_LEN)
    EXPAND STR_EQ copy_match, dst_view, src_view

    src_ok = eq src_match, 1
    fill_ok = eq fill_match, 1
    copy_ok = eq copy_match, 1
    ok01 = and src_ok, fill_ok
    ok = and ok01, copy_ok
    !src_match
    !fill_match
    !copy_match
    !src_ok
    !fill_ok
    !copy_ok
    !ok01
    !src_view
    !dst_view
    !expected_src
    !expected_fill
    !src
    !dst
    br ok -> L_OK, L_FAIL

L_FAIL:
    !ok
    panic(702)

L_OK:
    !ok
    return

@support_string_surface() -> void:
L_ENTRY:
    left = alloc Slice_SIZE
    same = alloc Slice_SIZE
    diff = alloc Slice_SIZE
    sub_expected = alloc Slice_SIZE
    joined_expected = alloc Slice_SIZE
    EXPAND SLICE_NEW left, &STR_EQ_LEFT, STR_EQ_LEFT_LEN
    EXPAND SLICE_NEW same, &STR_EQ_RIGHT, STR_EQ_RIGHT_LEN
    EXPAND SLICE_NEW diff, &STR_NE, STR_NE_LEN
    EXPAND SLICE_NEW sub_expected, &STR_SUB, STR_SUB_LEN
    EXPAND SLICE_NEW joined_expected, &STR_JOINED, STR_JOINED_LEN
    EXPAND STR_SLICE sub_slice, left, 1, STR_SUB_LEN
    EXPAND STR_EQ same_match, left, same
    EXPAND STR_EQ diff_match, left, diff
    EXPAND STR_EQ sub_match, sub_slice, sub_expected
    concat = call @sa_string_concat(*STR_JOIN_LEFT, STR_JOIN_LEFT_LEN, *STR_JOIN_RIGHT, STR_JOIN_RIGHT_LEN)
    concat_ok = ne concat, 0
    br concat_ok -> L_CONCAT, L_FAIL_CONCAT

L_FAIL_CONCAT:
    !same_match
    !diff_match
    !sub_match
    !sub_slice
    !left
    !same
    !diff
    !sub_expected
    !joined_expected
    !concat_ok
    panic(703)

L_CONCAT:
    concat_data = call @sa_fmt_buffer_data(&concat)
    concat_len = call @sa_fmt_buffer_len(&concat)
    concat_data_ok = ne concat_data, 0
    concat_len_ok = eq concat_len, STR_JOINED_LEN
    concat_view = alloc Slice_SIZE
    EXPAND SLICE_NEW concat_view, concat_data, concat_len
    concat_expected = alloc Slice_SIZE
    EXPAND SLICE_NEW concat_expected, &STR_JOINED, STR_JOINED_LEN
    EXPAND STR_EQ concat_match, concat_view, concat_expected

    same_ok = eq same_match, 1
    diff_ok = eq diff_match, 0
    sub_ok = eq sub_match, 1
    concat_match_ok = eq concat_match, 1
    ok01 = and same_ok, diff_ok
    ok02 = and ok01, sub_ok
    ok03 = and ok02, concat_data_ok
    ok04 = and ok03, concat_len_ok
    ok = and ok04, concat_match_ok
    concat_free_res = call @sa_fmt_buffer_free(^concat)
    concat_free_status = load concat_free_res+0 as i32
    !concat_free_res
    concat_free_ok = eq concat_free_status, 0
    ok = and ok, concat_free_ok
    !concat_match
    !same_match
    !diff_match
    !sub_match
    !same_ok
    !diff_ok
    !sub_ok
    !concat_match_ok
    !ok01
    !ok02
    !ok03
    !ok04
    !concat_data_ok
    !concat_len_ok
    !concat_free_status
    !concat_free_ok
    !concat_data
    !concat_len
    !sub_slice
    !left
    !same
    !diff
    !sub_expected
    !joined_expected
    !concat_view
    !concat_expected
    !concat_ok
    br ok -> L_OK, L_FAIL

L_FAIL:
    !ok
    panic(704)

L_OK:
    !ok
    return

@support_hashmap_surface() -> void:
L_ENTRY:
    EXPAND MAP_WITH_CAPACITY map, 9
    EXPAND MAP_LEN len0, map
    EXPAND MAP_CAPACITY cap0, map
    EXPAND MAP_IS_EMPTY empty0, map
    key = &HASHMAP_KEY
    value = &HASHMAP_VALUE
    EXPAND MAP_CONTAINS_KEY has0, map, key
    EXPAND MAP_PUT map, key, value
    EXPAND MAP_LEN len1, map
    EXPAND MAP_CAPACITY cap1, map
    EXPAND MAP_IS_EMPTY empty1, map
    EXPAND MAP_CONTAINS_KEY has1, map, key
    EXPAND MAP_GET got1, map, key
    EXPAND MAP_CLEAR map
    EXPAND MAP_LEN len2, map
    EXPAND MAP_IS_EMPTY empty2, map
    EXPAND MAP_CONTAINS_KEY has2, map, key
    EXPAND MAP_GET got2, map, key

    ok_len0 = eq len0, 0
    ok_cap0 = eq cap0, 16
    ok_empty0 = eq empty0, 1
    ok_has0 = eq has0, 0
    ok_len1 = eq len1, 1
    ok_cap1 = eq cap1, 16
    ok_empty1 = eq empty1, 0
    ok_has1 = eq has1, 1
    ok_got1 = eq got1, value
    ok_len2 = eq len2, 0
    ok_empty2 = eq empty2, 1
    ok_has2 = eq has2, 0
    ok_got2 = eq got2, 0
    ok01 = and ok_len0, ok_cap0
    ok02 = and ok01, ok_empty0
    ok03 = and ok02, ok_has0
    ok04 = and ok03, ok_len1
    ok05 = and ok04, ok_cap1
    ok06 = and ok05, ok_empty1
    ok07 = and ok06, ok_has1
    ok08 = and ok07, ok_got1
    ok09 = and ok08, ok_len2
    ok10 = and ok09, ok_empty2
    ok11 = and ok10, ok_has2
    ok = and ok11, ok_got2

    !got2
    !has2
    !empty2
    !len2
    !got1
    !has1
    !empty1
    !len1
    !has0
    !empty0
    !cap1
    !cap0
    !len0
    !value
    !key
    !ok_len0
    !ok_cap0
    !ok_empty0
    !ok_has0
    !ok_len1
    !ok_cap1
    !ok_empty1
    !ok_has1
    !ok_got1
    !ok_len2
    !ok_empty2
    !ok_has2
    !ok_got2
    !ok01
    !ok02
    !ok03
    !ok04
    !ok05
    !ok06
    !ok07
    !ok08
    !ok09
    !ok10
    !ok11
    EXPAND MAP_FREE map
    br ok -> L_OK, L_FAIL

L_FAIL:
    !ok
    panic(705)

L_OK:
    !ok
    return

@support_btree_surface() -> void:
L_ENTRY:
    map = 0 as ptr
    alpha = alloc Slice_SIZE
    bravo = alloc Slice_SIZE
    lookup = alloc Slice_SIZE
    EXPAND SLICE_NEW alpha, &BTREE_ALPHA, BTREE_ALPHA_LEN
    EXPAND SLICE_NEW bravo, &BTREE_BRAVO, BTREE_BRAVO_LEN
    EXPAND SLICE_NEW lookup, &BTREE_ALPHA, BTREE_ALPHA_LEN
    EXPAND BTREE_MAP_NEW map
    EXPAND BTREE_MAP_IS_EMPTY empty0, map
    EXPAND BTREE_MAP_INSERT map, bravo, 2
    EXPAND BTREE_MAP_INSERT map, alpha, 1
    EXPAND BTREE_MAP_INSERT map, lookup, 3
    EXPAND BTREE_MAP_CONTAINS_KEY has_alpha, map, alpha
    EXPAND BTREE_MAP_CONTAINS_KEY has_lookup, map, lookup
    value_alpha = call @sa_btree_map_get(&map, &alpha)
    value_bravo = call @sa_btree_map_get(&map, &bravo)
    removed_alpha = call @sa_btree_map_remove(&map, &alpha)
    EXPAND BTREE_MAP_CONTAINS_KEY has_alpha_after, map, alpha
    len = call @sa_btree_map_len(&map)
    EXPAND BTREE_MAP_CLEAR map
    EXPAND BTREE_MAP_IS_EMPTY empty1, map

    ok_alpha = eq value_alpha, 3
    ok_bravo = eq value_bravo, 2
    ok_removed = ne removed_alpha, 0
    ok_len = eq len, 1
    ok_empty0 = eq empty0, 1
    ok_empty1 = eq empty1, 1
    ok_has_alpha = eq has_alpha, 1
    ok_has_lookup = eq has_lookup, 1
    ok_has_alpha_after = eq has_alpha_after, 0
    ok01 = and ok_alpha, ok_bravo
    ok02 = and ok01, ok_removed
    ok03 = and ok02, ok_len
    ok04 = and ok03, ok_empty0
    ok05 = and ok04, ok_empty1
    ok06 = and ok05, ok_has_alpha
    ok07 = and ok06, ok_has_lookup
    ok = and ok07, ok_has_alpha_after
    !ok_has_alpha_after
    !ok_has_lookup
    !ok_has_alpha
    !ok_empty1
    !ok_empty0
    !ok_len
    !ok_removed
    !ok_bravo
    !ok_alpha
    !len
    !value_bravo
    !value_alpha
    !empty1
    !empty0
    !removed_alpha
    !has_alpha_after
    !has_lookup
    !has_alpha
    !lookup
    !bravo
    !alpha
    EXPAND BTREE_MAP_FREE map
    br ok -> L_OK, L_FAIL

L_FAIL:
    !ok
    panic(706)

L_OK:
    !ok
    return

@support_net_surface() -> void:
L_ENTRY:
    listener_res = call @sa_net_tcp_listener_bind(&NET_LOOPBACK, NET_LOOPBACK_LEN, 0)
    listener_status = load listener_res+0 as u32
    listener = load listener_res+8 as ptr
    !listener_res
    listener_status_ok = eq listener_status, 0
    listener_ok = ne listener, 0
    listener_all_ok = and listener_status_ok, listener_ok
    !listener_status_ok
    br listener_all_ok -> L_ADDR, L_FAIL_LISTENER

L_FAIL_LISTENER:
    !listener_all_ok
    !listener_status
    panic(707)

L_ADDR:
    !listener_ok
    addr_res = call @sa_net_tcp_listener_local_addr(listener)
    addr_status = load addr_res+0 as u32
    addr = load addr_res+8 as ptr
    !addr_res
    addr_status_ok = eq addr_status, 0
    addr_ok = ne addr, 0
    addr_all_ok = and addr_status_ok, addr_ok
    !addr_status_ok
    br addr_all_ok -> L_ADDR_COPY, L_FAIL_ADDR

L_FAIL_ADDR:
    !addr_ok
    close_listener_res = call @sa_net_tcp_listener_close(^listener)
    close_listener_status = load close_listener_res+4 as i32
    !close_listener_res
    !close_listener_status
    panic(708)

L_ADDR_COPY:
    !addr_ok
    host_ptr = call @sa_net_addr_host(&addr)
    host_len = call @sa_net_addr_host_len(&addr)
    port = call @sa_net_addr_port(&addr)
    family = call @sa_net_addr_family(&addr)
    host_copy = alloc host_len
    call @sa_mem_copy(&host_copy, &host_ptr, host_len)
    addr_free_res = call @sa_net_addr_free(^addr)
    addr_free_status = load addr_free_res+4 as i32
    !addr_free_res
    host_view = alloc Slice_SIZE
    expected_host = alloc Slice_SIZE
    EXPAND SLICE_NEW host_view, host_copy, host_len
    EXPAND SLICE_NEW expected_host, &NET_LOOPBACK, NET_LOOPBACK_LEN
    EXPAND STR_EQ host_match, host_view, expected_host

    host_ptr_ok = ne host_ptr, 0
    host_len_ok = eq host_len, NET_LOOPBACK_LEN
    port_ok = ne port, 0
    family_ok = eq family, SA_NET_AF_INET
    host_text_ok = eq host_match, 1
    addr_free_ok = eq addr_free_status, 0
    ok01 = and host_ptr_ok, host_len_ok
    ok02 = and ok01, port_ok
    ok03 = and ok02, family_ok
    ok04 = and ok03, host_text_ok
    ok = and ok04, addr_free_ok
    !host_match
    !host_ptr_ok
    !host_len_ok
    !port_ok
    !family_ok
    !ok01
    !ok02
    !ok03
    !ok04
    !host_view
    !expected_host
    !addr_free_status
    !host_ptr
    !family
    br ok -> L_CONNECT, L_FAIL_CONNECT

L_FAIL_CONNECT:
    !ok
    !host_text_ok
    !addr_free_ok
    !host_len
    !port
    !host_copy
    close_listener_res = call @sa_net_tcp_listener_close(^listener)
    close_listener_status = load close_listener_res+4 as i32
    !close_listener_res
    !close_listener_status
    panic(709)

L_CONNECT:
    connect_res = call @sa_net_tcp_connect(&host_copy, host_len, port)
    connect_status = load connect_res+0 as u32
    client = load connect_res+8 as ptr
    !connect_res
    connect_status_ok = eq connect_status, 0
    connect_ok = ne client, 0
    connect_all_ok = and connect_status_ok, connect_ok
    !connect_status_ok
    !host_len
    !port
    !host_copy
    br connect_all_ok -> L_ACCEPT, L_FAIL_CONNECT_CLIENT

L_FAIL_CONNECT_CLIENT:
    !host_text_ok
    !addr_free_ok
    !connect_all_ok
    close_listener_res = call @sa_net_tcp_listener_close(^listener)
    close_listener_status = load close_listener_res+4 as i32
    !close_listener_res
    !close_listener_status
    panic(710)

L_ACCEPT:
    accept_res = call @sa_net_tcp_listener_accept(listener)
    accept_status = load accept_res+0 as u32
    server = load accept_res+8 as ptr
    !accept_res
    accept_status_ok = eq accept_status, 0
    accept_ok = ne server, 0
    accept_all_ok = and accept_status_ok, accept_ok
    !accept_status_ok
    br accept_all_ok -> L_WRITE, L_FAIL_ACCEPT

L_FAIL_ACCEPT:
    !host_text_ok
    !addr_free_ok
    !accept_all_ok
    client_close_res = call @sa_net_tcp_stream_close(^client)
    client_close_status = load client_close_res+4 as i32
    !client_close_res
    listener_close_res = call @sa_net_tcp_listener_close(^listener)
    listener_close_status = load listener_close_res+4 as i32
    !listener_close_res
    !client_close_status
    !listener_close_status
    panic(711)

L_WRITE:
    send_res = call @sa_net_tcp_stream_write_all(client, &NET_MESSAGE, NET_MESSAGE_LEN)
    send_status = load send_res+0 as u32
    !send_res
    send_ok = eq send_status, 0
    !send_status
    br send_ok -> L_READ, L_FAIL_WRITE

L_FAIL_WRITE:
    !host_text_ok
    !addr_free_ok
    !send_ok
    server_close_res = call @sa_net_tcp_stream_close(^server)
    server_close_status = load server_close_res+4 as i32
    !server_close_res
    client_close_res = call @sa_net_tcp_stream_close(^client)
    client_close_status = load client_close_res+4 as i32
    !client_close_res
    listener_close_res = call @sa_net_tcp_listener_close(^listener)
    listener_close_status = load listener_close_res+4 as i32
    !listener_close_res
    !server_close_status
    !client_close_status
    !listener_close_status
    panic(712)

L_READ:
    read_buf = alloc NET_MESSAGE_LEN
    read_res = call @sa_net_tcp_stream_read(server, &read_buf, NET_MESSAGE_LEN)
    read_status = load read_res+0 as u32
    read_len = load read_res+8 as u64
    !read_res
    read_status_ok = eq read_status, 0
    read_ok = eq read_len, NET_MESSAGE_LEN
    read_all_ok = and read_status_ok, read_ok
    !read_status_ok
    br read_all_ok -> L_COMPARE, L_FAIL_READ

L_FAIL_READ:
    !host_text_ok
    !addr_free_ok
    !read_all_ok
    !read_len
    !read_buf
    server_close_res = call @sa_net_tcp_stream_close(^server)
    server_close_status = load server_close_res+4 as i32
    !server_close_res
    client_close_res = call @sa_net_tcp_stream_close(^client)
    client_close_status = load client_close_res+4 as i32
    !client_close_res
    listener_close_res = call @sa_net_tcp_listener_close(^listener)
    listener_close_status = load listener_close_res+4 as i32
    !listener_close_res
    !server_close_status
    !client_close_status
    !listener_close_status
    panic(713)

L_COMPARE:
    read_view = alloc Slice_SIZE
    expected_msg = alloc Slice_SIZE
    EXPAND SLICE_NEW read_view, read_buf, read_len
    EXPAND SLICE_NEW expected_msg, &NET_MESSAGE, NET_MESSAGE_LEN
    EXPAND STR_EQ msg_match, read_view, expected_msg
    msg_ok = eq msg_match, 1
    !msg_match
    !read_view
    !expected_msg
    !read_buf
    server_close_res = call @sa_net_tcp_stream_close(^server)
    server_close_status = load server_close_res+4 as i32
    !server_close_res
    client_close_res = call @sa_net_tcp_stream_close(^client)
    client_close_status = load client_close_res+4 as i32
    !client_close_res
    listener_close_res = call @sa_net_tcp_listener_close(^listener)
    listener_close_status = load listener_close_res+4 as i32
    !listener_close_res

    close_ok0 = eq server_close_status, 0
    close_ok1 = eq client_close_status, 0
    close_ok2 = eq listener_close_status, 0
    close01 = and close_ok0, close_ok1
    close_ok = and close01, close_ok2
    ok01 = and host_text_ok, addr_free_ok
    ok02 = and ok01, connect_ok
    ok03 = and ok02, accept_ok
    ok04 = and ok03, send_ok
    ok05 = and ok04, read_ok
    ok06 = and ok05, msg_ok
    ok = and ok06, close_ok

    !server_close_status
    !client_close_status
    !listener_close_status
    !close_ok0
    !close_ok1
    !close_ok2
    !close01
    !close_ok
    !ok01
    !ok02
    !ok03
    !ok04
    !ok05
    !ok06
    !host_text_ok
    !addr_free_ok
    !read_len
    br ok -> L_DONE, L_FAIL_DONE

L_FAIL_DONE:
    panic(714)

L_DONE:
    return
