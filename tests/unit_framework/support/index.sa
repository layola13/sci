@support_read_twice(&value: ptr) -> i32:
L_ENTRY:
    a = load value+0 as i32
    b = load value+0 as i32
    sum = add a, b
    !a
    !b
    !value
    return sum

@support_identity(value: i32) -> i32:
L_ENTRY:
    return value

@support_fill_zero(&arr: ptr) -> void:
L_ENTRY:
    i_slot = stack_alloc 8
    store i_slot+0, 0 as u64
    jmp L_COND

L_COND:
    i = load i_slot+0 as u64
    more = ult i, 4
    br more -> L_BODY, L_END

L_BODY:
    slot = ptr_add arr, i
    store slot+0, 0 as u8
    next = add i, 1
    store i_slot+0, next as u64
    !slot
    !next
    !i
    !more
    jmp L_COND

L_END:
    !i
    !more
    !arr
    return

@support_sum_1_to_5() -> i64:
L_ENTRY:
    i_slot = stack_alloc 8
    sum_slot = stack_alloc 8
    store i_slot+0, 1 as i64
    store sum_slot+0, 0 as i64
    jmp L_COND

L_COND:
    i = load i_slot+0 as i64
    sum = load sum_slot+0 as i64
    more = sle i, 5
    br more -> L_BODY, L_END

L_BODY:
    sum_next = add sum, i
    i_next = add i, 1
    !sum
    !i
    !more
    store sum_slot+0, sum_next as i64
    store i_slot+0, i_next as i64
    !sum_next
    !i_next
    jmp L_COND

L_END:
    !i
    !more
    return sum

@support_factorial(n: i32) -> i32:
L_ENTRY:
    done = sle n, 1
    br done -> L_BASE, L_RECURSE

L_BASE:
    !done
    !n
    return 1

L_RECURSE:
    !done
    prev = sub n, 1
    rec = call @support_factorial(prev)
    result = mul n, rec
    !n
    !rec
    return result

@support_fib(n: i32) -> i32:
L_ENTRY:
    base = sle n, 1
    br base -> L_BASE, L_REC

L_BASE:
    !base
    return n

L_REC:
    !base
    n1 = sub n, 1
    n2 = sub n, 2
    a = call @support_fib(n1)
    b = call @support_fib(n2)
    sum = add a, b
    !n
    !a
    !b
    return sum

@support_double_u64(x: u64) -> u64:
L_ENTRY:
    y = add x, x
    return y

@support_unwrap_or_i32(^opt: ptr, default: i32) -> i32:
L_ENTRY:
    EXPAND OPTION_IS_SOME has_value, opt
    br has_value -> L_SOME, L_NONE

L_SOME:
    !has_value
    !default
    EXPAND OPTION_GET value, opt
    !opt
    return value

L_NONE:
    !has_value
    !opt
    return default

@support_choose_option_default(&opt: ptr, fallback: i32) -> i32:
L_ENTRY:
    value = load opt+Option_value as u64
    tag = load opt+Option_tag as u64
    is_some = eq tag, Option_SOME
    br is_some -> L_SOME, L_NONE

L_SOME:
    !tag
    !is_some
    !opt
    !fallback
    return value

L_NONE:
    !tag
    !is_some
    return fallback
