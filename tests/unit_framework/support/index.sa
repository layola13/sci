@support_profile_guided_opt_total() -> i32:
L_ENTRY:
    total_slot = stack_alloc 8
    idx_slot = stack_alloc 8
    store total_slot+0, 0 as i32
    store idx_slot+0, 0 as i32
    jmp L_LOOP

L_LOOP:
    total = load total_slot+0 as i32
    idx = load idx_slot+0 as i32
    done = eq idx, 3
    br done -> L_AFTER_LOOP, L_HOT

L_HOT:
    value = add 3, 0
    total_next = add total, value
    idx_next = add idx, 1
    store total_slot+0, total_next as i32
    store idx_slot+0, idx_next as i32
    !value
    !total
    !idx
    !done
    !total_next
    !idx_next
    jmp L_LOOP

L_AFTER_LOOP:
    cold = add 1, 0
    total2 = add total, cold
    !cold
    !total
    !idx
    !done
    return total2

