@support_if_let_chain_sum() -> i32:
L_ENTRY:
    left = alloc Option_SIZE
    middle = alloc Option_SIZE
    right = alloc Option_SIZE
    EXPAND OPTION_SET_SOME left, 2
    EXPAND OPTION_SET_SOME middle, 3
    EXPAND OPTION_SET_SOME right, 4
    EXPAND OPTION_IS_SOME left_ok, left
    br left_ok -> L_LEFT, L_FAIL_LEFT

L_LEFT:
    EXPAND OPTION_GET x, left
    EXPAND OPTION_IS_SOME middle_ok, middle
    br middle_ok -> L_MIDDLE, L_FAIL_MIDDLE

L_MIDDLE:
    EXPAND OPTION_GET y, middle
    EXPAND OPTION_IS_SOME right_ok, right
    br right_ok -> L_RIGHT, L_FAIL_RIGHT

L_RIGHT:
    EXPAND OPTION_GET z, right
    partial = add x, y
    result = add partial, z
    !z
    !partial
    !right_ok
    !y
    !middle_ok
    !x
    !left_ok
    !right
    !middle
    !left
    return result

L_FAIL_RIGHT:
    !right_ok
    !middle_ok
    !y
    !x
    !left_ok
    !right
    !middle
    !left
    return 0

L_FAIL_MIDDLE:
    !middle_ok
    !x
    !left_ok
    !right
    !middle
    !left
    return 0

L_FAIL_LEFT:
    !left_ok
    !right
    !middle
    !left
    return 0

