    !result
    !sum
    !right
    !left
    !tally_value
    !tally
    return total

@support_raii_inspect(^lock: ptr, skip: i32) -> i32:
L_ENTRY:
    guard = alloc 8
    store guard+0, lock as ptr
    held = load lock+SupportLock_held as i32
    unlocked = eq held, 0
    br unlocked -> L_ENTER, L_FAIL

L_ENTER:
    store lock+SupportLock_held, 1 as i32
    skip_now = ne skip, 0
    br skip_now -> L_SKIP, L_UPDATE

L_SKIP:
    current = load lock+SupportLock_value as i32
    store lock+SupportLock_held, 0 as i32
    !skip_now
    !held
    !unlocked
    !guard
    !lock
    return current

L_UPDATE:
    current = load lock+SupportLock_value as i32
    next = add current, 3
    store lock+SupportLock_value, next as i32
    store lock+SupportLock_held, 0 as i32
    !skip_now
    !held
    !unlocked
    !current
    !guard
    !lock
    return next

L_FAIL:
    !held
    !unlocked
    !guard
    !lock
    panic(102)

