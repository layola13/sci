[MACRO] SUPPORT_CAPTURE %dst, %value
    %dst = add %value, 0
[END_MACRO]

[MACRO] SUPPORT_SUM3 %out, %a, %b, %c
    __support_sum3_tmp_%out = add %a, %b
    %out = add __support_sum3_tmp_%out, %c
    !__support_sum3_tmp_%out
[END_MACRO]

[MACRO] SUPPORT_BUILD %left, %middle, %right, %mirror
    EXPAND SUPPORT_SUM3 result, %left, %middle, %right
    EXPAND SUPPORT_CAPTURE %mirror, result
[END_MACRO]

