    store entity+SupportEcoEntity_X, 147 as i32
    store entity+SupportEcoEntity_Y, 148 as i32
    store entity+SupportEcoEntity_VX, 1 as i32
    store entity+SupportEcoEntity_VY, 1 as i32
    value = call @support_eco_step_entity(&entity)
    !entity
    return value

