@support_atomic_spin_lock_once() -> i32:
L_ENTRY:
    lock = alloc SupportAtomic_SIZE
    store lock+SupportAtomic_value, 0 as i32
    state = atomic_load lock+SupportAtomic_value as i32 acquire
    free = eq state, 0
    br free -> L_LOCK, L_FAIL

L_LOCK:
    old, ok = cmpxchg lock+SupportAtomic_value, 0, 1 as i32 acquire relaxed
    br ok -> L_CRITICAL, L_FAIL_LOCK

L_CRITICAL:
    atomic_store lock+SupportAtomic_value, 0 as i32 release
    final = atomic_load lock+SupportAtomic_value as i32 acquire
    !ok
    !old
    !free
    !state
    !lock
    return final

L_FAIL_LOCK:
    !ok
    !old
    !free
    !state
    !lock
    return -1

L_FAIL:
    !free
    !state
    !lock
    return -1

