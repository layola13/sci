    store outer+SupportGuard_value, 1 as i32
    inner = alloc SupportGuard_SIZE
    store inner+SupportGuard_tally, tally as ptr
    store inner+SupportGuard_value, 10 as i32
    left = add 2, 0
    right = add 3, 0
    sum = add left, right
    result = add sum, 0
    dropped_inner = call @support_guard_drop(&inner)
    !dropped_inner
    !inner
    dropped_outer = call @support_guard_drop(&outer)
    !dropped_outer
