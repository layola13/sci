@support_eco_step_entity(&entity: ptr) -> i32:
L_ENTRY:
    x = load entity+SupportEcoEntity_X as i32
    y = load entity+SupportEcoEntity_Y as i32
    vx = load entity+SupportEcoEntity_VX as i32
    vy = load entity+SupportEcoEntity_VY as i32
    next_x = add x, vx
    next_y = add y, vy
    store entity+SupportEcoEntity_X, next_x as i32
    store entity+SupportEcoEntity_Y, next_y as i32
    sum = add next_x, next_y
    !x
    !y
    !vx
    !vy
    !next_x
    !next_y
    !entity
    return sum

@support_eco_game_engine_ecs_value() -> i32:
L_ENTRY:
