@support_pick_max(a: i32, b: i32) -> i32:
L_ENTRY:
    choose_a = sgt a, b
    br choose_a -> L_A, L_B

L_A:
    !choose_a
    !b
    return a

L_B:
    !choose_a
    !a
    return b

@support_make_point(x: i32, y: i32) -> ptr:
L_ENTRY:
    point = alloc 8
    store point+0, x as i32
    store point+4, y as i32
    !x
    !y
    return point

@support_sum_point(^point: ptr) -> i32:
L_ENTRY:
    px = load point+0 as i32
    py = load point+4 as i32
    sum = add px, py
    !px
    !py
    !point
    return sum

@support_dispatch_msg(tag: u32, x: i32, y: i32) -> i32:
L_ENTRY:
    is_move = eq tag, 1
    br is_move -> L_MOVE, L_OTHER

L_MOVE:
    !is_move
    sum = add x, y
    !x
    !y
    return sum

L_OTHER:
    !is_move
    panic(106)

@support_button_draw(&self: ptr) -> i32:
L_ENTRY:
    id = load self+SupportButton_id as i32
    !self
    return id

@support_trait_render(&item: ptr) -> i32:
L_ENTRY:
    data_ptr = load item+SupportDynDraw_DATA as ptr
    vtable_ptr = load item+SupportDynDraw_VTABLE as ptr
    draw_fn = load vtable_ptr+SupportVTable_draw as ptr
    result = call_indirect draw_fn(&data_ptr)
    !draw_fn
    !vtable_ptr
    !data_ptr
    !item
    return result

@support_trait_vtable_render() -> i32:
L_ENTRY:
    button = alloc SupportButton_SIZE
    store button+SupportButton_id, 77 as i32
    fat = alloc SupportDynDraw_SIZE
    store fat+SupportDynDraw_DATA, button as ptr
    store fat+SupportDynDraw_VTABLE, &SUPPORT_BUTTON_VT as ptr
    result = call @support_trait_render(&fat)
    !button
    !fat
    return result

@support_closure_add_offset_call(&env: ptr, x: i32) -> i32:
L_ENTRY:
    offset = load env+SupportEnv_offset as i32
    result = add x, offset
    !offset
    !env
    !x
    return result

@support_closure_add_offset(x: i32) -> i32:
L_ENTRY:
    env = alloc SupportEnv_SIZE
    store env+SupportEnv_offset, 5 as i32
    result = call @support_closure_add_offset_call(&env, x)
    !env
    return result

@support_tuple_pair_fields() -> i32:
L_ENTRY:
    pair = alloc SupportPair_SIZE
    store pair+SupportPair_0, 3 as i32
    store pair+SupportPair_1, 4 as i32
    left = load pair+SupportPair_0 as i32
    right = load pair+SupportPair_1 as i32
    ok_left = eq left, 3
    ok_right = eq right, 4
    ok = and ok_left, ok_right
    !left
    !right
    !ok_left
    !ok_right
    !pair
    return ok

@support_destructure_pair_sum() -> i32:
L_ENTRY:
    pair = alloc SupportPair_SIZE
    store pair+SupportPair_0, 2 as i32
    store pair+SupportPair_1, 5 as i32
    x = load pair+SupportPair_0 as i32
    y = load pair+SupportPair_1 as i32
    sum = add x, y
    !x
    !y
    !pair
    return sum

@support_array_sum_4() -> i32:
L_ENTRY:
    arr = alloc 16
    store arr+0, 1 as i32
    store arr+4, 2 as i32
    store arr+8, 3 as i32
    store arr+12, 4 as i32
    a = load arr+0 as i32
    b = load arr+4 as i32
    c = load arr+8 as i32
    d = load arr+12 as i32
    ab = add a, b
    cd = add c, d
    sum = add ab, cd
    !a
    !b
    !c
    !d
    !ab
    !cd
    !arr
    return sum

@support_sum_two_slice(&slice: ptr) -> i32:
L_ENTRY:
    EXPAND SLICE_GET_PTR data, slice
    first = load data+0 as i32
    second_ptr = ptr_add data, 4
    second = load second_ptr+0 as i32
    sum = add first, second
    !first
    !second_ptr
    !second
    !data
    !slice
    return sum

@support_slice_window_sum() -> i32:
L_ENTRY:
    values = alloc 16
    store values+0, 1 as i32
    store values+4, 2 as i32
    store values+8, 3 as i32
    store values+12, 4 as i32
    slice = alloc Slice_SIZE
    start = ptr_add values, 4
    EXPAND SLICE_NEW slice, start, 2
    sum = call @support_sum_two_slice(&slice)
    !start
    !slice
    !values
    return sum

@support_counter_new(seed: i32) -> ^ptr:
L_ENTRY:
    counter = alloc SupportCounter_SIZE
    value = add seed, 2
    store counter+SupportCounter_value, value as i32
    !seed
    !value
    return counter

@support_counter_new_value(seed: i32) -> i32:
L_ENTRY:
    counter = call @support_counter_new(seed)
    value = load counter+SupportCounter_value as i32
    !counter
    return value

@support_counter_inc(&counter: ptr) -> void:
L_ENTRY:
    value = load counter+SupportCounter_value as i32
    next = add value, 1
    store counter+SupportCounter_value, next as i32
    !value
    !next
    !counter
    return

@support_method_counter_after_inc() -> i32:
L_ENTRY:
    counter = alloc SupportCounter_SIZE
    store counter+SupportCounter_value, 3 as i32
    call @support_counter_inc(&counter)
    value = load counter+SupportCounter_value as i32
    !counter
    return value

@support_eval_guard(&opt: ptr) -> i32:
L_ENTRY:
    EXPAND OPTION_IS_SOME is_some, opt
    br is_some -> L_SOME, L_NONE

L_SOME:
    value = load opt+Option_value as i32
    pass = gt value, 3
    br pass -> L_HIT, L_MISS

L_HIT:
    !pass
    !is_some
    !opt
    return value

L_MISS:
    !pass
    !value
    !is_some
    !opt
    return 0

L_NONE:
    !is_some
    !opt
    return -1

@support_iterator_map_total() -> i32:
L_ENTRY:
    a = mul 1, 2
    b = mul 2, 2
    c = mul 3, 2
    ab = add a, b
    total = add ab, c
    !a
    !b
    !c
    !ab
    return total

@support_iterator_filter_total() -> i32:
L_ENTRY:
    keep_a = add 2, 0
    keep_b = add 4, 0
    total = add keep_a, keep_b
    !keep_a
    !keep_b
    return total

@support_account_deposit(&account: ptr, amount: i32) -> void:
L_ENTRY:
    balance = load account+SupportAccount_balance as i32
    next = add balance, amount
    store account+SupportAccount_balance, next as i32
    !balance
    !next
    !amount
    !account
    return

@support_account_after_deposit() -> i32:
L_ENTRY:
    account = alloc SupportAccount_SIZE
    store account+SupportAccount_balance, 10 as i32
    call @support_account_deposit(&account, 5)
    balance = load account+SupportAccount_balance as i32
    !account
    return balance

@support_exported_value() -> i32:
L_ENTRY:
    return 7

@support_internal_value() -> i32:
L_ENTRY:
    return 5

@support_export_visibility_total() -> i32:
L_ENTRY:
    left = call @support_exported_value()
    right = call @support_internal_value()
    total = add left, right
    !left
    !right
    return total

@support_config_merge_check() -> i32:
L_ENTRY:
    base = alloc SupportConfig_SIZE
    override_cfg = alloc SupportConfig_SIZE
    store base+SupportConfig_threads, 4 as u32
    store base+SupportConfig_level, 1 as u32
    store override_cfg+SupportConfig_threads, 0 as u32
    store override_cfg+SupportConfig_level, 3 as u32
    base_threads = load base+SupportConfig_threads as u32
    base_level = load base+SupportConfig_level as u32
    over_threads = load override_cfg+SupportConfig_threads as u32
    over_level = load override_cfg+SupportConfig_level as u32
    use_threads = ne over_threads, 0
    use_level = ne over_level, 0
    br use_threads -> L_THREADS_SET, L_THREADS_KEEP

L_THREADS_SET:
    threads_value = add over_threads, 0
    jmp L_LEVEL

L_THREADS_KEEP:
    threads_value = add base_threads, 0
    jmp L_LEVEL

L_LEVEL:
    br use_level -> L_LEVEL_SET, L_LEVEL_KEEP

L_LEVEL_SET:
    level_value = add over_level, 0
    jmp L_DONE

L_LEVEL_KEEP:
    level_value = add base_level, 0
    jmp L_DONE

L_DONE:
    threads_ok = eq threads_value, 4
    level_ok = eq level_value, 3
    ok = and threads_ok, level_ok
    !base_threads
    !base_level
    !over_threads
    !over_level
    !use_threads
    !use_level
    !threads_value
    !level_value
    !threads_ok
    !level_ok
    !base
    !override_cfg
    return ok

@support_enum_branch_value() -> i32:
L_ENTRY:
    flag = alloc SupportFlag_SIZE
    store flag+SupportFlag_tag, 1 as u32
    tag = load flag+SupportFlag_tag as u32
    is_a = eq tag, 0
    br is_a -> L_A, L_B

L_A:
    !tag
    !is_a
    !flag
    return 1

L_B:
    !tag
    !is_a
    !flag
    return 2

@support_newtype_user_id() -> u32:
L_ENTRY:
    user = alloc SupportUserId_SIZE
    store user+SupportUserId_value, 42 as u32
    value = load user+SupportUserId_value as u32
    !user
    return value

@support_generic_struct_i32() -> i32:
L_ENTRY:
    wrapped = alloc SupportWrapper_i32_SIZE
    store wrapped+SupportWrapper_i32_value, 31 as i32
    value = load wrapped+SupportWrapper_i32_value as i32
    !wrapped
    return value

@support_generic_enum_i32() -> i32:
L_ENTRY:
    value_slot = alloc SupportMaybe_SIZE
    store value_slot+SupportMaybe_tag, SupportMaybe_TAG_VALUE as i32
    store value_slot+SupportMaybe_value, 7 as i32
    tag = load value_slot+SupportMaybe_tag as i32
    is_value = eq tag, SupportMaybe_TAG_VALUE
    br is_value -> L_VALUE, L_EMPTY

L_VALUE:
    result = load value_slot+SupportMaybe_value as i32
    !tag
    !is_value
    !value_slot
    return result

L_EMPTY:
    !tag
    !is_value
    !value_slot
    return 0

@support_generic_pair_sum(a: i32, b: i32) -> i32:
L_ENTRY:
    total = add a, b
    !a
    !b
    return total

@support_lookup_route(&route: ptr) -> i32:
L_ENTRY:
    id = load route+SupportRoute_id as i32
    !route
    return id

@support_router_table_lookup() -> i32:
L_ENTRY:
    route = alloc SupportRoute_SIZE
    store route+SupportRoute_path, 0 as i32
    store route+SupportRoute_id, 2 as i32
    id = call @support_lookup_route(&route)
    !route
    return id

@support_lookup_cache(&cache_entry: ptr) -> i32:
L_ENTRY:
    value = load cache_entry+SupportCacheEntry_value as i32
    !cache_entry
    return value

@support_cache_hits_lookup() -> i32:
L_ENTRY:
    cache_entry = alloc SupportCacheEntry_SIZE
    store cache_entry+SupportCacheEntry_key, 0 as i32
    store cache_entry+SupportCacheEntry_value, 3 as i32
    value = call @support_lookup_cache(&cache_entry)
    !cache_entry
    return value

@support_mem_fill_all_seven() -> i32:
L_ENTRY:
    buffer = alloc 4
    call @sa_mem_set(&buffer, 7, 4)
    b0 = load buffer+0 as u8
    b1 = load buffer+1 as u8
    b2 = load buffer+2 as u8
    b3 = load buffer+3 as u8
    ok0 = eq b0, 7
    ok1 = eq b1, 7
    ok2 = eq b2, 7
    ok3 = eq b3, 7
    pair0 = and ok0, ok1
    pair1 = and ok2, ok3
    ok = and pair0, pair1
    !b0
    !b1
    !b2
    !b3
    !ok0
    !ok1
    !ok2
    !ok3
    !pair0
    !pair1
    !buffer
    return ok

@support_advance_state(state: i32) -> i32:
L_ENTRY:
    next = add state, 1
    !state
    return next

@support_state_machine_advance() -> i32:
L_ENTRY:
    state = call @support_advance_state(1)
    return state

@support_count_tokens(a: i32, b: i32, c: i32, d: i32) -> i32:
L_ENTRY:
    ab = add a, b
    cd = add c, d
    total = add ab, cd
    !a
    !b
    !c
    !d
    !ab
    !cd
    return total

@support_parser_token_count() -> i32:
L_ENTRY:
    total = call @support_count_tokens(1, 1, 1, 1)
    return total

@support_serializer_id() -> i32:
L_ENTRY:
    return 7

@support_service_users() -> i32:
L_ENTRY:
    return 2

@support_service_orders() -> i32:
L_ENTRY:
    return 4

@support_integration_service_total() -> i32:
L_ENTRY:
    users = call @support_service_users()
    orders = call @support_service_orders()
    total = add users, orders
