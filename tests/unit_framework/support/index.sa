@support_executor_task_queue_total() -> i32:
L_ENTRY:
    queue = alloc SupportQueue_SIZE
    store queue+SupportQueue_head, 0 as i32
    store queue+SupportQueue_tail, 3 as i32
    store queue+SupportQueue_t0, 1 as i32
    store queue+SupportQueue_t1, 2 as i32
    store queue+SupportQueue_t2, 3 as i32
    total = 0
    jmp L_LOOP

L_LOOP:
    head = load queue+SupportQueue_head as i32
    tail = load queue+SupportQueue_tail as i32
    more = ult head, tail
    br more -> L_DEQUEUE, L_DONE

L_DEQUEUE:
    is_head0 = eq head, 0
    is_head1 = eq head, 1
    br is_head0 -> L_LOAD0, L_HEAD1

L_HEAD1:
    br is_head1 -> L_LOAD1, L_LOAD2

L_LOAD0:
    slot = load queue+SupportQueue_t0 as i32
    jmp L_RUN

L_LOAD1:
    slot = load queue+SupportQueue_t1 as i32
    jmp L_RUN

L_LOAD2:
    slot = load queue+SupportQueue_t2 as i32
    jmp L_RUN

L_RUN:
    value = call @support_run_task(&queue, slot)
    next_total = add total, value
    !total
    store queue+SupportQueue_sum, next_total as i32
    next_head = add head, 1
    store queue+SupportQueue_head, next_head as i32
    !slot
    !value
    !next_head
    !head
    !tail
    !more
    !is_head0
    !is_head1
    total = next_total
    jmp L_LOOP

L_DONE:
    !head
    !tail
    !more
    !queue
    return total

