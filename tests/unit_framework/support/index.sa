    first = call @support_raii_inspect(^first_lock, 1)
    second_lock = alloc SupportLock_SIZE
    store second_lock+SupportLock_value, 0 as i32
    store second_lock+SupportLock_held, 0 as i32
    second = call @support_raii_inspect(^second_lock, 0)
    total = add first, second
    !first
    !second
    return total

