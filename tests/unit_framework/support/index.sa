@support_ffi_callback_step(value: i32) -> i32:
L_ENTRY:
    next = add value, 1
    !value
    return next

@support_ffi_callback_thunk_value() -> i32:
L_ENTRY:
    state = alloc 16
    store state+SupportFfiCallbackState_value, 289 as i32
    store state+SupportFfiCallbackState_vtable, &SUPPORT_FFI_CALLBACK_VT as ptr
    view = assume_borrow state
    vt = load view+SupportFfiCallbackState_vtable as ptr
    fn = load vt+SupportFfiCallbackVTable_call as ptr
    value = load view+SupportFfiCallbackState_value as i32
    result = call_indirect fn(value)
    store view+SupportFfiCallbackState_value, result as i32
    !value
    !fn
    !vt
    !view
    !state
    return result

@support_eco_pair_sum(*slot: ptr) -> i32:
L_ENTRY:
    view = assume_borrow slot
    a = load view+SupportEcoPair_a as i32
    b = load view+SupportEcoPair_b as i32
    result = add a, b
    !b
    !a
    !view
    return result

@support_eco_pair_entry(value: i32, delta: i32) -> i32:
L_ENTRY:
    slot = alloc 8
    store slot+SupportEcoPair_a, value as i32
    store slot+SupportEcoPair_b, delta as i32
    result = call @support_eco_pair_sum(*slot)
    !slot
    return result

