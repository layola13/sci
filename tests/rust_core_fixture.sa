@import "sa_std/core/option.sal"
@import "sa_std/core/option.sa"
@import "sa_std/core/result.sal"
@import "sa_std/core/result.sa"
@import "sa_std/core/panic.sa"
@import "sa_std/core/slice.sal"
@import "sa_std/core/slice.sa"
@import "sa_std/core/iter.sal"
@import "sa_std/core/iter.sa"

@double(x: u64) -> u64:
L_ENTRY:
    y = add x, x
    return y

@default_value() -> u64:
L_ENTRY:
    return 99

@main() -> i32:
L_ENTRY:
    opt = alloc Option_SIZE
    store opt+Option_tag, Option_SOME as u64
    store opt+Option_value, 7 as u64
    EXPAND OPTION_IS_SOME is_some, opt
    EXPAND OPTION_IS_NONE is_none, opt
    EXPAND OPTION_GET got, opt
    EXPAND OPTION_UNWRAP unwrapped, opt
    EXPAND OPTION_UNWRAP_OR fallback_value, opt, 0
    EXPAND OPTION_MAP_OR mapped_default, opt, @double, 0
    EXPAND OPTION_MAP_OR_ELSE mapped_else, opt, @double, @default_value
    EXPAND OPTION_BRANCH opt, L_OPT_SOME, L_OPT_NONE

L_OPT_SOME:
    EXPAND RESULT_NEW_OK res, got
    EXPAND RESULT_IS_OK is_ok, res
    EXPAND RESULT_IS_ERR is_err, res
    EXPAND RESULT_GET_OK ok_value, res
    EXPAND RESULT_UNWRAP unwrapped_ok, res
    EXPAND RESULT_UNWRAP_OR defaulted_ok, res, 0
    EXPAND RESULT_MAP_OR result_mapped, res, @double, 0
    EXPAND RESULT_MAP_OR_ELSE result_mapped_else, res, @double, @default_value
    EXPAND RESULT_BRANCH res, L_RES_OK, L_RES_ERR

L_RES_OK:
    slice = alloc Slice_SIZE
    store slice+Slice_ptr, opt as ptr
    store slice+Slice_len, 1 as u64
    EXPAND ITER_FROM_SLICE iter, slice
    EXPAND ITER_IS_EMPTY iter_empty, iter
    EXPAND ITER_HAS_NEXT iter_has_next, iter
    EXPAND ITER_LEN iter_len, iter
    EXPAND ITER_REMAINING iter_remaining, iter
    EXPAND ITER_PEEK_U64 iter_peek, iter
    EXPAND ITER_NEXT_U64 iter_has, iter_item, iter
    EXPAND PANIC 0

L_RES_ERR:
    EXPAND PANIC_MSG 1, opt, 8

L_OPT_NONE:
    EXPAND PANIC 2
