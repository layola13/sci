@import "sa_std/io/print.sai"
@import "sa_std/time.sa"

@const RESULT_OK = utf8:"time ok\n"

@main() -> i32!:
L_ENTRY:
    EXPAND TIME_NOW_NS mono_ns
    EXPAND TIME_NOW_UNIX_MS unix_ms
    date = alloc TimeDate_SIZE
    EXPAND TIME_UTC_NOW date
    EXPAND TIME_SLEEP_MS 0
    !mono_ns
    !unix_ms
    !date
    call @sa_print_bytes(&RESULT_OK, 8)
    return 0
