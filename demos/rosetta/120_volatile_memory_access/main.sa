@import "sa_std/io/print.sai"

@const RESULT_OK = utf8:"5\n"
@const RESULT_ERR = utf8:"error\n"

@main() -> i32:
L_ENTRY:
    node = alloc 4
    store node+0, 5 as i32
    seen = load node+0 as i32
    ok = eq seen, 5
    !seen
    !node
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 2)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
