@import "sa_std/io/print.sai"

@const RESULT_OK = utf8:"2\n"
@const RESULT_ERR = utf8:"error\n"

@advance(state: i32) -> i32:
L_ENTRY:
    next = add state, 1
    !state
    return next

@main() -> i32:
L_ENTRY:
    state = call @advance(1)
    ok = eq state, 2
    !state
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 2)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
