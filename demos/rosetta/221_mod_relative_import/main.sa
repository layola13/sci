@import "sa_std/io/print.sai"
@import "helper.sa"

@const RESULT_OK = utf8:"221\n"
@const RESULT_ERR = utf8:"error\n"

// 221 - Mod Relative Import
// main -> helper -> chain/step -> chain/deeper/seed.

@main() -> i32:
L_ENTRY:
    value = call @helper_value()
    ok = eq value, 221
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 4)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
