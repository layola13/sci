@import "sa_std/io/print.sai"
@import "bridge/index.sa"

@const RESULT_OK = utf8:"224\n"
@const RESULT_ERR = utf8:"error\n"

// 224 - Mod Reexport Pub Use
// bridge/index.sa forwards to a deeper module instead of exposing it directly.

@main() -> i32:
L_ENTRY:
    value = call @bridge_value()
    ok = eq value, 224
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 4)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
