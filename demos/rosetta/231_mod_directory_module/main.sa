@import "sa_std/io/print.sai"
@import "module/index.sa"

@const RESULT_OK = utf8:"231\n"
@const RESULT_ERR = utf8:"error\n"

// 231 - Mod Directory Module
// module/index.sa acts as the module root.

@main() -> i32:
L_ENTRY:
    value = call @directory_value()
    ok = eq value, 231
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 4)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
