@import "../../../sa_std/io/print.saasm-iface"

@const RESULT_OK = utf8:"query user\n"
@const RESULT_ERR = utf8:"error\n"

@handle_query() -> i32:
L_ENTRY:
    return 0

@main() -> i32:
L_ENTRY:
    status = call @handle_query()
    ok = eq status, 0
    !status
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 11)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
