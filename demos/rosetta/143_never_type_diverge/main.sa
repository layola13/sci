@import "sa_std/io/print.sai"

@const RESULT_OK = utf8:"0\n"
@const RESULT_ERR = utf8:"error\n"

// Never (!) 类型降级为没有返回块，必定发散 (diverge) 的函数。
@fail() -> void:
L_ENTRY:
    panic(99)

@main() -> i32:
L_ENTRY:
    safe = add 1, 0
    br safe -> L_SAFE, L_FAIL

L_FAIL:
    !safe
    call @fail()
    return 1

L_SAFE:
    !safe
    call @sa_print_bytes(&RESULT_OK, 2)
    return 0
