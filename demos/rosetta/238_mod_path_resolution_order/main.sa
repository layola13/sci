@import "sa_std/io/print.sai"
@import "paths/index.sa"

@const RESULT_OK = utf8:"238\n"
@const RESULT_ERR = utf8:"error\n"

// 238 - Mod Path Resolution Order
// The wrapper imports first/ before second/ in a fully explicit order.

@main() -> i32:
L_ENTRY:
    value = call @path_value()
    ok = eq value, 238
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 4)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
