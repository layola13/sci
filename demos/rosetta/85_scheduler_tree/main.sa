@import "sa_std/io/print.sai"

@const RESULT_OK = utf8:"6\n"
@const RESULT_ERR = utf8:"error\n"

@sum_tree(a: i32, b: i32, c: i32) -> i32:
L_ENTRY:
    ab = add a, b
    total = add ab, c
    !a
    !b
    !c
    !ab
    return total

@main() -> i32:
L_ENTRY:
    total = call @sum_tree(1, 2, 3)
    ok = eq total, 6
    !total
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 2)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
