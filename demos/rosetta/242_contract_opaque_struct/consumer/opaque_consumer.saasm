@import "../layout/public.saasm-layout"
@import "../bridge/opaque_bridge.saasm"

@opaque_consumer_value() -> i32:
L_ENTRY:
    opaque = alloc Opaque_SIZE
    value = call @opaque_bridge_value(&opaque)
    ok = eq value, 242
    !value
    !opaque
    br ok -> L_OK, L_ERR

L_OK:
    return 242

L_ERR:
    return 0
