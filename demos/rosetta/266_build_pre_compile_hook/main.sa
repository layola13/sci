@import "sa_std/io/print.sai"
@import "generated/precompile.sa"

@const RESULT_OK = utf8:"266\n"
@const RESULT_ERR = utf8:"error\n"

// 266 - Build Pre Compile Hook
// hooks/pre-compile.sh runs before the generated SA-ASM is imported.

@main() -> i32:
L_ENTRY:
    value = call @precompile_value()
    ok = eq value, 266
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 4)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
