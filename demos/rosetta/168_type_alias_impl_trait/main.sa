@import "sa_std/io/print.sai"

@const RESULT_OK = utf8:"0\n"
@const RESULT_ERR = utf8:"error\n"

// TAIT 抽象类型由前端解析为具体的物理结构尺寸。
#def ConcreteIter_SIZE = 16

@make_iter() -> ^ptr:
L_ENTRY:
    iter = alloc ConcreteIter_SIZE
    return iter

@main() -> i32:
L_ENTRY:
    iter = call @make_iter()
    !iter
    
    ok = eq 0, 0
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 2)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
