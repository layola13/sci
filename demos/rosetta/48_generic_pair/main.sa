@import "sa_std/io/print.sai"

@const RESULT_OK = utf8:"11,31\n"
@const RESULT_ERR = utf8:"error\n"

@pair_sum(a: i32, b: i32) -> i32:
L_ENTRY:
    total = add a, b
    !a
    !b
    return total

@main() -> i32:
L_ENTRY:
    left = call @pair_sum(11, 31)
    ok = eq left, 42
    !left
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 6)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
