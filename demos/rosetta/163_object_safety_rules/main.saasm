@import "../../../sa_std/io/print.saasm-iface"

@const RESULT_OK = utf8:"4\n"
@const RESULT_ERR = utf8:"error\n"

#def Item_SIZE = 0

@draw_item(&self: ptr) -> i32:
L_ENTRY:
    !self
    return 4

@main() -> i32:
L_ENTRY:
    item = alloc 1
    result = call @draw_item(&item)
    ok = eq result, 4
    !result
    !item
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 2)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
