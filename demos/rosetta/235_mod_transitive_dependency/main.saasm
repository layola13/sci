@import "../../../sa_std/io/print.saasm-iface"
@import "dep/index.saasm"

@const RESULT_OK = utf8:"235\n"
@const RESULT_ERR = utf8:"error\n"

// 235 - Mod Transitive Dependency
// Main -> dep/index -> dep/mid -> dep/leaf.

@main() -> i32:
L_ENTRY:
    value = call @transitive_value()
    ok = eq value, 235
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 4)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
