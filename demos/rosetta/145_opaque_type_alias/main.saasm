@import "../../../sa_std/io/print.saasm-iface"

@const RESULT_OK = utf8:"5\n"
@const RESULT_ERR = utf8:"error\n"

#def Item_SIZE = 0

@make_item(&self: ptr) -> i32:
L_ENTRY:
    !self
    return 5

@main() -> i32:
L_ENTRY:
    item = alloc 1
    result = call @make_item(&item)
    ok = eq result, 5
    !result
    !item
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 2)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
