@import "sa_std/io/print.sai"
@import "generated/postcompile.sa"

@const RESULT_OK = utf8:"267\n"
@const RESULT_ERR = utf8:"error\n"

// 267 - Build Post Compile Hook
// hooks/post-compile.sh writes artifacts beside the generated module.

@main() -> i32:
L_ENTRY:
    value = call @postcompile_value()
    ok = eq value, 267
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 4)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
