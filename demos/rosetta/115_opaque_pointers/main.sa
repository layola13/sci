@import "sa_std/io/print.sai"

@const RESULT_OK = utf8:"0\n"
@const RESULT_ERR = utf8:"error\n"

@export opaque_value(ptr: ptr) -> i32:
L_ENTRY:
    return 0

@main() -> i32:
L_ENTRY:
    raw = alloc 1
    result = call @opaque_value(raw)
    ok = eq result, 0
    !result
    !raw
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 2)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
