@import "../../../sa_std/io/print.saasm-iface"
@import "lint/index.saasm"

@const RESULT_OK = utf8:"234\n"
@const RESULT_ERR = utf8:"error\n"

// 234 - Mod Unused Import Lint
// lint/index.saasm pulls in an unused branch on purpose.

@main() -> i32:
L_ENTRY:
    value = call @lint_value()
    ok = eq value, 234
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 4)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
