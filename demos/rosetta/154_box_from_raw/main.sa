@import "sa_std/io/print.sai"

@const RESULT_OK = utf8:"11\n"
@const RESULT_ERR = utf8:"error\n"

@main() -> i32:
L_ENTRY:
    raw = alloc 4
    store raw+0, 11 as i32
    boxed = raw
    value = load boxed+0 as i32
    ok = eq value, 11
    !value
    !boxed
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 3)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
