@import "../../../sa_std/io/print.saasm-iface"

@const RESULT_OK = utf8:"sa> \n"
@const RESULT_ERR = utf8:"error\n"

@prompt() -> i32:
L_ENTRY:
    return 1

@main() -> i32:
L_ENTRY:
    value = call @prompt()
    ok = eq value, 1
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 5)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
