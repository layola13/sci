@import "index.saasm-iface"
@import "index.saasm-layout"
@import "core/seed.saasm"

@export prelude_value() -> i32:
L_ENTRY:
    slot = alloc Prelude_SIZE
    seed = call @prelude_seed()
    store slot+Prelude_value, seed as i32
    loaded = load slot+Prelude_value as i32
    value = add loaded, 200
    !seed
    !loaded
    !slot
    return value
