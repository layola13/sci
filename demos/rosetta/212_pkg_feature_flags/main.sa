@import "sa_std/io/print.sai"
@import "src/index.sa"

@const RESULT_OK = utf8:"212\n"
@const RESULT_ERR = utf8:"error\n"

// 212 - Pkg Feature Flags
// The package tree keeps a nested helper folder under src/flags/helpers.

@main() -> i32:
L_ENTRY:
    value = call @src_package_value()
    ok = eq value, 212
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 4)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
