@import "sa_std/io/print.sai"
@import "src/index.sa"

@const RESULT_OK = utf8:"213\n"
@const RESULT_ERR = utf8:"error\n"

// 213 - Pkg Default Features
// The default feature package lives under src/defaults/helpers.

@main() -> i32:
L_ENTRY:
    value = call @src_package_value()
    ok = eq value, 213
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 4)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
