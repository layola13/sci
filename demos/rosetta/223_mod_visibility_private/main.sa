@import "sa_std/io/print.sai"
@import "public/index.sa"

@const RESULT_OK = utf8:"223\n"
@const RESULT_ERR = utf8:"error\n"

// 223 - Mod Visibility Private
// main only sees the public wrapper; the private chain stays in internal/.

@main() -> i32:
L_ENTRY:
    value = call @public_value()
    ok = eq value, 223
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 4)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
