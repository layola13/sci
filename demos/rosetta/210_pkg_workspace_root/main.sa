@import "sa_std/io/print.sai"
@import "workspace/index.sa"

@const RESULT_OK = utf8:"210\n"
@const RESULT_ERR = utf8:"error\n"

// 210 - Package Workspace Root
// The root workspace aggregates two member packages with their own manifests.

@main() -> i32:
L_ENTRY:
    value = call @workspace_total()
    ok = eq value, 210
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 4)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
