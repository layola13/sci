@import "sa_std/io/print.sai"
@import "ffi/group/index.sa"

@const RESULT_OK = utf8:"236\n"
@const RESULT_ERR = utf8:"error\n"

// 236 - Mod Extern Block Grouping
// A grouped iface file feeds a grouped bridge module.

@main() -> i32:
L_ENTRY:
    value = call @ffi_group_value()
    ok = eq value, 236
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 4)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
