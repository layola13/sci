@import "handle_gate.saasm-layout"
@import "../ffi/handle.saasm-iface"

@ffi_wrapper handle_gate(*slot: ptr) -> i32:
L_ENTRY:
    view = assume_borrow slot
    tag = load view+HandleSlot_tag as i32
    refcount = load view+HandleSlot_refcount as i32
    result = add tag, refcount
    !refcount
    !tag
    !view
    return result
