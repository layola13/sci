@import "sa_std/io/print.sai"
@import "profiles/index.sa"

@const RESULT_OK = utf8:"232\n"
@const RESULT_ERR = utf8:"error\n"

// 232 - Mod Conditional Import
// Ordinary imports model the chosen profile branch explicitly.

@main() -> i32:
L_ENTRY:
    value = call @selected_value()
    ok = eq value, 232
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 4)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
