@import "sa_std/io/print.sai"
@import "crypto/hash.sa"

@const RESULT_OK = utf8:"298\n"
@const RESULT_ERR = utf8:"error\n"

// 298 - Eco Cryptography Simd
// The SIMD story is a crypto module plus host-side benchmark and header notes.

@main() -> i32:
L_ENTRY:
    value = call @crypto_hash_entry()
    ok = eq value, 298
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 4)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
