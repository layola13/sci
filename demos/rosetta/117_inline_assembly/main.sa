@import "sa_std/io/print.sai"

@const RESULT_OK = utf8:"7\n"
@const RESULT_ERR = utf8:"error\n"

@main() -> i32:
L_ENTRY:
    value = alloc 4
    store value+0, 7 as i32
    $call void asm sideeffect "", ""()$
    result = load value+0 as i32
    ok = eq result, 7
    !result
    !value
    br ok -> L_OK, L_ERR

L_OK:
    !ok
    call @sa_print_bytes(&RESULT_OK, 2)
    return 0

L_ERR:
    !ok
    call @sa_print_bytes(&RESULT_ERR, 6)
    return 1
